 Desde 350€/mês.\"/><meta name=\"application-name\" content=\"Element Group\"/><link rel=\"manifest\" href=\"/manifest.json\"/><meta name=\"robots\" content=\"index, follow, max-image-preview:large\"/><link rel=\"canonical\" href=\"https://elementgroup.pt/servicos/marketing-digital\"/><meta name=\"mobile-web-app-capable\" content=\"yes\"/><meta name=\"apple-mobile-web-app-title\" content=\"Element Group\"/><meta name=\"apple-mobile-web-app-status-bar-style\" content=\"default\"/><meta property=\"og:title\" content=\"Marketing Digital para PMEs em Portugal | desde 350€/mês | Element Group\"/><meta property=\"og:description\" content=\"Gestão de Instagram, Facebook e Google Ads para PMEs em Portugal. SEO mensal, conteúdo criativo e relatórios de performance incluídos. Desde 350€/mês.\"/><meta property=\"og:url\" content=\"https://elementgroup.pt/servicos/marketing-digital\"/><meta property=\"og:image\" content=\"https://elementgroup.pt/og-image.jpg\"/><meta property=\"og:image:width\" content=\"1200\"/><meta property=\"og:image:height\" content=\"630\"/><meta name=\"twitter:card\" content=\"summary_large_image\"/><meta name=\"twitter:title\" content=\"Element Group — Sites, Apps &amp; Marketing Digital para PMEs\"/><meta name=\"twitter:description\" content=\"Soluções digitais à medida para PMEs em Portugal: websites, lojas online, apps mobile, branding e marketing digital. Propostas em 24h.\"/><meta name=\"twitter:image\" content=\"https://elementgroup.pt/og-image.jpg\"/><link rel=\"icon\" href=\"/favicon.ico\" type=\"image/x-icon\" sizes=\"48x48\"/><link rel=\"icon\" href=\"/icon0.svg?3b8331f96fba45c7\" type=\"image/svg+xml\" sizes=\"any\"/><link rel=\"icon\" href=\"/icon1.png?2dccf3bf3254d5b8\" type=\"image/png\" sizes=\"96x96\"/><link rel=\"apple-touch-icon\" href=\"/apple-icon.png?903b574816cb18b2\" type=\"image/png\" sizes=\"180x180\"/><script src=\"/_next/static/chunks/polyfills-42372ed130431b0a.js\" noModule=\"\"></script></head><body><div hidden=\"\"><!--$-->