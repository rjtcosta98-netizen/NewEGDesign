alse]},null,false],\"$Ld\",false]],\"m\":\"$undefined\",\"G\":[\"$e\",[]],\"s\":false,\"S\":true}\n10:I[3340,[\"77\",\"static/chunks/77-2d69a11fd87f0c4e.js\",\"133\",\"static/chunks/app/(pages)/layout-f31902d4af3cc87d.js\"],\"default\"]\n11:I[3077,[\"77\",\"static/chunks/77-2d69a11fd87f0c4e.js\",\"979\",\"static/chunks/app/(pages)/servicos/%5Bslug%5D/page-1cbe908fc1828673.js\"],\"\"]\n13:I[1777,[],\"OutletBoundary\"]\n15:I[8732,[],\"AsyncMetadataOutlet\"]\n17:I[1777,[],\"ViewportBoundary\"]\n19:I[1777,[],\"MetadataBoundary\"]\n1a:\"$Sreact.suspense\"\n6:[\"$\",\"$L4\",null,{\"id\":\"ld-website\",\"type\":\"application/ld+json\",\"strategy\":\"afterInteractive\",\"dangerouslySetInnerHTML\":{\"__html\":\"{\\\"@context\\\":\\\"https://schema.org\\\",\\\"@type\\\":\\\"WebSite\\\",\\\"@id\\\":\\\"https://elementgroup.pt/#website\\\",\\\"url\\\":\\\"https://elementgroup.pt/\\\",\\\"name\\\":\\\"Element Group\\\",\\\"inLanguage\\\":\\\"pt-PT\\\",\\\"publisher\\\":{\\\"@id\\\":\\\"https://elementgroup.pt/#organization\\\"}}\"}}]\n7:[\"$\",\"$L4\",null,{\"id\":\"ld-breadcrumb\",\"type\":\"application/ld+json\",\"strategy\":\"afterInteractive\",\"dangerouslySetInnerHTML\":{\"__html\":\"{\\\"@context\\\":\\\"https://schema.org\\\",\\\"@type\\\":\\\"BreadcrumbList\\\",\\\"itemListElement\\\":[{\\\"@type\\\":\\\"ListItem\\\",\\\"position\\\":1,\\\"name\\\":\\\"Início\\\",\\\"item\\\":\\\"https://elementgroup.pt/\\\"},{\\\"@type\\\":\\\"ListItem\\\",\\\"position\\\":2,\\\"name\\\":\\\"Serviços\\\",\\\"item\\\":\\\"https://elementgroup.pt/servicos\\\"},{\\\"@type\\\":\\\"ListItem\\\",\\\"position\\\":3,\\\"name\\\":\\\"Portfólio\\\",\\\"item\\\":\\\"https://elementgroup.pt/portfolio\\\"},{\\\"@type\\\":\\\"ListItem\\\",\\\"position\\\":4,\\\"name\\\":\\\"Blog\\\",\\\"item\\\":\\\"https://elementgroup.pt/blog\\\"},{\\\"@type\\\":\\\"ListItem\\\",\\\"position\\\":5,\\\"name\\\":\\\"Contacto\\\",\\\"item\\\":\\\"https://elementgroup.pt/#contacto\\\"}]}\"}}]\nf:Tf61,{\"@context\":\"https://schema.org\",\"@type\":\"FAQPage\",\"mainEntity\":[{\"@type\":\"Question\",\"name\":\"Quanto custa fazer um website em Portugal?\",\"acceptedAnswer\":{\"@type\":\"Answer\",\"text\":\"Na Element Group, um website profissional começa em 197€ (pagamento único). Lojas online a partir de 997€ e apps mobile a partir de 1.497€. Onde agências tradicionais em Portugal facturam tipicamente entre €2.000 e €5.000 por sites comparáveis, conseguimos ser mais acessíveis porque usamos tecnologia moderna que reduz o tempo de produção sem comprometer qualidade.\"}},{\"@type\":\"Question\",\"name\":\"Qual a melhor agência digital para PMEs em Portugal?\",\"acceptedAnswer\":{\"@type\":\"Answer\",\"text\":\"A Element Group é uma agência digital portuguesa especializada em PMEs, com PageSpeed 95+ por defeito, preços a partir de 197€, propostas em 24 horas e apoio pós-lançamento incluído. Serve clientes em todo o território nacional remotamente.\"}},{\"@type\":\"Question\",\"name\":\"Quanto custa criar uma loja online em Portugal?\",\"acceptedAnswer\":{\"@type\":\"Answer\",\"text\":\"Uma loja online completa na Element Group começa em 997€ (pagamento único). Inclui checkout MBWay, Multibanco e cartão, gestão de produtos e stock, faturação automática portuguesa e SEO. Prazo de entrega: 4 a 6 semanas.\"}},{\"@type\":\"Question\",\"name\":\"Quanto tempo demora a fazer um site profissional?\",\"acceptedAnswer\":{\"@type\":\"Answer\",\"text\":\"Sites institucionais: 2 a 3 semanas. Lojas online: 4 a 6 semanas. Apps mobile: 6 a 8 semanas. Branding e logótipo: 1 a 2 semanas.\"}},{\"@type\":\"Question\",\"name\":\"Que serviços oferece a Element Group?\",\"acceptedAnswer\":{\"@type\":\"Answer\",\"text\":\"Criação de websites, lojas online (e-commerce), apps mobile (iOS, Android, PWA), design gráfico, branding, SEO técnico, SEO local e marketing digital — soluções completas para PMEs em Portugal.\"}},{\"@type\":\"Question\",\"name\":\"Oferecem apoio após o lançamento?\",\"acceptedAnswer\":{\"@type\":\"Answer\",\"text\":\"Sim. Todos os projetos incluem apoio pós-entrega, monitorização de performance e pequenas alterações sem custo adicional, dentro do âmbito acordado.\"}},{\"@type\":\"Question\",\"name\":\"Posso ver exemplos de trabalhos?\",\"acceptedAnswer\":{\"@type\":\"Answer\",\"text\":\"Sim. Casos: Apiários Terras da Pulga (loja online), Maria Mendes Massagens (Top 3 Google Local), AD São Romão (portal), Estrela Detail & Wash (branding) e Football Nation Store (e-commerce + branding). Casos de estudo detalhados disponíveis por email.\"}},{\"@type\":\"Question\",\"name\":\"Como funcionam os pagamentos?\",\"acceptedAnswer\":{\"@type\":\"Answer\",\"text\":\"Aceitamos pagamento único com 5% de desconto, ou 2× prestações sem juros. Métodos: MBWay, Multibanco e transferência bancária.\"}},{\"@type\":\"Question\",\"name\":\"Oferecem alojamento e domínio?\",\"acceptedAnswer\":{\"@type\":\"Answer\",\"text\":\"Sim. Tratamos do registo de domínio e alojamento performante com SSL incluído. Disponível como add-on mensal.\"}},{\"@type\":\"Question\",\"name\":\"Quantas alterações posso pedir?\",\"acceptedAnswer\":{\"@type\":\"Answer\",\"text\":\"Dentro do âmbito acordado, alterações são ilimitadas. Trabalhamos por aprovações em cada fase para evitar surpresas.\"}},{\"@type\":\"Question\",\"name\":\"O SEO está incluído nos pacotes?\",\"acceptedAnswer\":{\"@type\":\"Answer\",\"text\":\"SEO técnico, schema markup e otimização on-page estão sempre incluídos em todos os projetos. SEO mensal contínuo é opcional no pacote de Marketing Digital (desde 350€/mês).\"}},{\"@type\":\"Question\",\"name\":\"Element Group vs WordPress: qual escolher?\",\"acceptedAnswer\":{\"@type\":\"Answer\",\"text\":\"Sites WordPress com templates pré-feitos têm tipicamente performance média (PageSpeed 50-70) e dependem de plugins que aumentam a superfície de ataque e abrandam o site. A Element Group entrega sites à medida com PageSpeed 95+, sem plugins desnecessários e com SEO técnico avançado, a preços competitivos a partir de 197€.\"}}]}8:[\"$\",\"$L4\",null,{\"id\":\"ld-faq\",\"type\":\"application/ld+json\",\"strategy\":\"afterInteractive\",\"dangerouslySetInnerHTML\":{\"__html\":\"$f\"}}]\n9:[\"$\",\"$1\",\"c\",{\"children\":[null,[[\"$\",\"$L10\",null,{}],[\"$\",\"main\",null,{\"children\":[\"$\",\"$L2\",null,{\"parallelRouterKey\":\"children\",\"error\":\"$undefined\",\"errorStyles\":\"$undefined\",\"errorScripts\":\"$undefined\",\"template\":[\"$\",\"$L3\",null,{}],\"templateStyles\":\"$undefined\",\"templateScripts\":\"$undefined\",\"notFound\":[[[\"$\",\"title\",null,{\"children\":\"404: This page could not be found.\"}],[\"$\",\"div\",null,{\"style\":\"$0:f:0:1:1:props:children:1:props:children:props:children:0:props:notFound:0:1:props:style\",\"children\":[\"$\",\"div\",null,{\"children\":[[\"$\",\"style\",null,{\"dangerouslySetInnerHTML\":{\"__html\":\"body{color:#000;background:#fff;margin:0}.next-error-h1{border-right:1px solid rgba(0,0,0,.3)}@media (prefers-color-scheme:dark){body{color:#fff;background:#000}.next-error-h1{border-right:1px solid rgba(255,255,255,.3)}}\"}}],[\"$\",\"h1\",null,{\"className\":\"next-error-h1\",\"style\":\"$0:f:0:1:1:props:children:1:props:children:props:children:0:props:notFound:0:1:props:children:props:children:1:props:style\",\"children\":404}],[\"$\",\"div\",null,{\"style\":\"$0:f:0:1:1:props:children:1:props:children:props:children:0:props:notFound:0:1:props:children:props:children:2:props:style\",\"children\":[\"$\",\"h2\",null,{\"style\":\"$0:f:0:1:1:props:children:1:props:children:props:children:0:props:notFound:0:1:props:children:props:children:2:props:children:props:style\",\"children\":\"This page could not be found.\"}]}]]}]}]],[]],\"forbidden\":\"$undefined\",\"unauthorized\":\"$undefined\"}]}],[\"$\",\"footer\",null,{\"className\":\"site-footer\",\"children\":[\"$\",\"div\",null,{\"className\":\"container\",\"children\":[[\"$\",\"div\",null,{\"className\":\"site-footer-grid\",\"children\":[[\"$\",\