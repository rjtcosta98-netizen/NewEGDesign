\"error\":\"$undefined\",\"errorStyles\":\"$undefined\",\"errorScripts\":\"$undefined\",\"template\":[\"$\",\"$L3\",null,{}],\"templateStyles\":\"$undefined\",\"templateScripts\":\"$undefined\",\"notFound\":\"$undefined\",\"forbidden\":\"$undefined\",\"unauthorized\":\"$undefined\"}]]}]\nc:[\"$\",\"$1\",\"c\",{\"children\":[\"$L12\",null,[\"$\",\"$L13\",null,{\"children\":[\"$L14\",[\"$\",\"$L15\",null,{\"promise\":\"$@16\"}]]}]]}]\nd:[\"$\",\"$1\",\"h\",{\"children\":[null,[[\"$\",\"$L17\",null,{\"children\":\"$L18\"}],[\"$\",\"meta\",null,{\"name\":\"next-size-adjust\",\"content\":\"\"}]],[\"$\",\"$L19\",null,{\"children\":[\"$\",\"div\",null,{\"hidden\":true,\"children\":[\"$\",\"$1a\",null,{\"fallback\":null,\"children\":\"$L1b\"}]}]}]]}]\n1c:I[9732,[\"77\",\"static/chunks/77-2d69a11fd87f0c4e.js\",\"979\",\"static/chunks/app/(pages)/servicos/%5Bslug%5D/page-1cbe908fc1828673.js\"],\"ServiceTheme\"]\n1d:T752,{\"@context\":\"https://schema.org\",\"@type\":\"FAQPage\",\"mainEntity\":[{\"@type\":\"Question\",\"name\":\"Qual a diferença entre uma app nativa e uma PWA?\",\"acceptedAnswer\":{\"@type\":\"Answer\",\"text\":\"Uma app nativa (iOS/Android) é instalada da App Store ou Google Play e tem acesso total ao hardware do dispositivo. Uma PWA funciona no browser, não precisa de instalação e é mais rápida de desenvolver. Recomendamos PWA para casos de uso mais simples e apps nativas para funcionalidades avançadas (câmara, notificações, pagamentos in-app).\"}},{\"@type\":\"Question\",\"name\":\"Quanto tempo demora o desenvolvimento de uma app?\",\"acceptedAnswer\":{\"@type\":\"Answer\",\"text\":\"6 a 8 semanas para apps standard. Apps mais complexas com integrações avançadas podem levar 10 a 14 semanas. O prazo inclui design, desenvolvimento, testes e publicação nas stores.\"}},{\"@type\":\"Question\",\"name\":\"Ficam responsáveis pela publicação na App Store e Google Play?\",\"acceptedAnswer\":{\"@type\":\"Answer\",\"text\":\"Sim. Tratamos de toda a documentação e assets necessários para aprovação nas stores. Tens de ter conta de developer (Apple Developer Program: $99/ano; Google Play: $25 único) — podemos orientar-te no processo de criação.\"}},{\"@type\":\"Question\",\"name\":\"Posso adicionar funcionalidades após o lançamento?\",\"acceptedAnswer\":{\"@type\":\"Answer\",\"text\":\"Sim. O desenvolvimento é modular e documentado para que novas funcionalidades possam ser adicionadas facilmente. Oferecemos também contratos de manutenção mensal para updates contínuos.\"}},{\"@type\":\"Question\",\"name\":\"As vossas apps passam na revisão da Apple?\",\"acceptedAnswer\":{\"@type\":\"Answer\",\"text\":\"Sim. Conhecemos as diretrizes da App Store e desenvolvemos em conformidade. Nunca tivemos um projeto rejeitado definitivamente — casos de pedido de informação adicional foram resolvidos em menos de 48 horas.\"}}]}12:[\"$\",\"div\",null,{\"className\":\"svc-page\",\"data-color\":\"cyan\",\"children\":[[\"$\",\"$L1c\",null,{\"color\":\"cyan\"}],[\"$\",\"$L4\",null,{\"id\":\"ld-svc-apps-mobile\",\"type\":\"application/ld+json\",\"strategy\":\"afterInteractive\",\"dangerouslySetInnerHTML\":{\"__html\":\"{\\\"@context\\\":\\\"https://schema.org\\\",\\\"@type\\\":\\\"Service\\\",\\\"@id\\\":\\\"https://elementgroup.pt/servicos/apps-mobile#service\\\",\\\"name\\\":\\\"Apps Mobile\\\",\\\"description\\\":\\\"Desenvolvimento de apps mobile para iOS e Android em Portugal desde 1.497€. Apps nativas e PWA com painel de gestão incluído. Notificações push e integração com APIs.\\\",\\\"url\\\":\\\"https://elementgroup.pt/servicos/apps-mobile\\\",\\\"provider\\\":{\\\"@type\\\":\\\"ProfessionalService\\\",\\\"@id\\\":\\\"https://elementgroup.pt/#organization\\\",\\\"name\\\":\\\"Element Group\\\",\\\"url\\\":\\\"https://elementgroup.pt\\\"},\\\"areaServed\\\":{\\\"@type\\\":\\\"Country\\\",\\\"name\\\":\\\"Portugal\\\"},\\\"offers\\\":{\\\"@type\\\":\\\"Offer\\\",\\\"price\\\":1497,\\\"priceCurrency\\\":\\\"EUR\\\",\\\"availability\\\":\\\"https://s