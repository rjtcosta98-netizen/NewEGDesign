min-height:160px;border-radius:8px;overflow:hidden;border:1px solid var(--line)\\\"\\u003e\\u003cimg src=\\\"https://ctflpbjvsepkbfjpgkuh.supabase.co/storage/v1/object/public/project-images/football-projeto.webp\\n\\n\\\" alt=\\\"Website - Football Nation Store\\\" loading=\\\"lazy\\\" decoding=\\\"async\\\" style=\\\"position:absolute;inset:0;width:100%;height:100%;object-fit:cover\\\"/\\u003e\\u003c/div\\u003e\\n            \\u003c/div\\u003e\\n          \\u003c/div\\u003e\\n        \\u003c/div\\u003e\\n        \\u003cdiv class=\\\"wk-meta\\\"\\u003e\\n          \\u003cdiv class=\\\"wk-titles\\\"\\u003e\\n            \\u003ch3\\u003eWebsite - Football Nation Store\\u003c/h3\\u003e\\n            \\u003cp\\u003eLoja online completa para venda de camisolas de futebol com catálogo, pagamentos e SEO.\\u003c/p\\u003e\\n          \\u003c/div\\u003e\\n          \\u003cspan class=\\\"wk-tag\\\"\\u003ewebsite\\u003c/span\\u003e\\n        \\u003c/div\\u003e\\n      \\u003c/a\\u003e\\u003c/div\\u003e\\n  \\u003c/div\\u003e\\n\\u003c/section\\u003e\\n\\n\\u003c!-- ========= COMPARAÇÃO ========= --\\u003e\\n\\u003csection class=\\\"has-atmos\\\"\\u003e\\n  \\u003cdiv class=\\\"section-atmos\\\" aria-hidden=\\\"true\\\"\\u003e\\n    \\u003cdiv class=\\\"rings\\\"\\u003e\\u003cspan\\u003e\\u003c/span\\u003e\\u003cspan\\u003e\\u003c/span\\u003e\\u003cspan\\u003e\\u003c/span\\u003e\\u003cspan\\u003e\\u003c/span\\u003e\\u003cspan\\u003e\\u003c/span\\u003e\\u003cspan\\u003e\\u003c/span\\u003e\\u003c/div\\u003e\\n    \\u003cdiv class=\\\"section-sparkles\\\"\\u003e\\n      \\u003cspan style=\\\"left:14%;top:80px;animation-delay:.7s\\\"\\u003e\\u003c/span\\u003e\\n      \\u003cspan style=\\\"left:22%;top:180px;animation-delay:2.0s\\\"\\u003e\\u003c/span\\u003e\\n      \\u003cspan style=\\\"left:30%;top:60px;animation-delay:1.5s\\\"\\u003e\\u003c/span\\u003e\\n      \\u003cspan style=\\\"left:42%;top:130px;animation-delay:.3s\\\"\\u003e\\u003c/span\\u003e\\n      \\u003cspan style=\\\"left:50%;top:200px;animation-delay:2.6s\\\"\\u003e\\u003c/span\\u003e\\n      \\u003cspan style=\\\"left:58%;top:90px;animation-delay:1.0s\\\"\\u003e\\u003c/span\\u003e\\n      \\u003cspan style=\\\"left:66%;top:170px;animation-delay:3.2s\\\"\\u003e\\u003c/span\\u003e\\n      \\u003cspan style=\\\"left:74%;top:60px;animation-delay:1.9s\\\"\\u003e\\u003c/span\\u003e\\n      \\u003cspan style=\\\"left:82%;top:150px;animation-delay:.5s\\\"\\u003e\\u003c/span\\u003e\\n      \\u003cspan style=\\\"left:88%;top:220px;animation-delay:2.4s\\\"\\u003e\\u003c/span\\u003e\\n    \\u003c/div\\u003e\\n  \\u003c/div\\u003e\\n  \\u003cdiv class=\\\"container\\\"\\u003e\\n    \\u003cdiv class=\\\"section-head reveal\\\"\\u003e\\n      \\u003cspan class=\\\"eyebrow\\\"\\u003eComparação\\u003c/span\\u003e\\n      \\u003ch2 class=\\\"section-title\\\"\\u003eElement Group vs \\u003cem\\u003eOutras Agências\\u003c/em\\u003e\\u003c/h2\\u003e\\n      \\u003cp class=\\\"section-sub\\\"\\u003eVê porque é que somos a escolha mais inteligente para o teu próximo projeto digital.\\u003c/p\\u003e\\n    \\u003c/div\\u003e\\n\\n    \\u003cdiv class=\\\"vs-wrap reveal\\\"\\u003e\\n      \\u003cdiv class=\\\"vs-heads\\\"\\u003e\\n        \\u003ch3\\u003eOutras agências\\u003c/h3\\u003e\\n        \\u003cspan class=\\\"brand\\\"\\u003e\\u003cspan class=\\\"e\\\"\\u003eE\\u003c/span\\u003e Element Group\\u003c/span\\u003e\\n        \\u003cdiv class=\\\"vs-badge\\\"\\u003eV/S\\u003c/div\\u003e\\n      \\u003c/div\\u003e\\n      \\u003cdiv class=\\\"vs-rows\\\"\\u003e\\n        \\u003cdiv class=\\\"vs-cell lose\\\"\\u003e\\u003cspan class=\\\"vs-ic\\\"\\u003e×\\u003c/span\\u003eTemplates pré-feitos, design igual a centenas de sites.\\u003c/div\\u003e\\n        \\u003cdiv class=\\\"vs-cell win\\\"\\u003e\\u003cspan class=\\\"vs-ic\\\"\\u003e⚡\\u003c/span\\u003eDesign 100% à medida, único para o teu negócio.\\u003c/div\\u003e\\n\\n        \\u003cdiv class=\\\"vs-cell lose\\\"\\u003e\\u003cspan class=\\\"vs-ic\\\"\\u003e×\\u003c/span\\u003eApoio limitado pós-entrega — ficas por tua conta.\\u003c/div\\u003e\\n        \\u003cdiv class=\\\"vs-cell win\\\"\\u003e\\u003cspan class=\\\"vs-ic\\\"\\u003e⚡\\u003c/span\\u003eApoio contínuo incluído, sempre que precisares.\\u003c/div\\u003e\\n\\n        \\u003cdiv class=\\\"vs-cell lose\\\"\\u003e\\u003cspan class=\\\"vs-ic\\\"\\u003e×\\u003c/span\\u003ePerformance média e tempos de carregamento lentos.\\u003c/div\\u003e\\n        \\u003cdiv class=\\\"vs-cell win\\\"\\u003e\\u003cspan class=\\\"vs-ic\\\"\\u003e⚡\\u003c/span\\u003ePageSpeed 95+ e velocidade de topo por defeito.\\u003c/div\\u003e\\n\\n        \\u003cdiv class=\\\"vs-cell lose\\\"\\u003e\\u003cspan class=\\\"vs-ic\\\"\\u003e×\\u003c/span\\u003ePreços inflacionados: €2.000 – €5.000 por trabalhos básicos.\\u003c/div\\u003e\\n        \\u003cdiv class=\\\"vs-cell win\\\"\\u003e\\u003cspan class=\\\"vs-ic\\\"\\u003e⚡\\u003c/span\\u003ePreços justos desde 197€ — tecnologia moderna, custo reduzido.\\u003c/div\\u003e\\n\\n        \\u003cdiv class=\\\"vs-cell lose\\\"\\u003e\\u003cspan class=\\\"vs-ic\\\"\\u003e×\\u003c/span\\u003eSEO básico, com pouca presença local.\\u003c/div\\u003e\\n        \\u003cdiv class=\\\"vs-cell win\\\"\\u003e\\u003cspan class=\\\"vs-ic\\\"\\u003e⚡\\u003c/span\\u003eSEO técnico avançado e Google Maps Top 3.\\u003c/div\\u003e\\n      \\u003c/div\\u003e\\n    \\u003c/div\\u003e\\n  \\u003c/div\\u003e\\n\\u003c/section\\u003e\\n\\n\\u003c!-- ========= INSIGHTS — Stats com fontes citadas ========= --\\u003e\\n\\u003csection id=\\\"insights\\\" class=\\\"insights-band\\\"\\u003e\\n  \\u003cdiv class=\\\"ib-beams\\\" aria-hidden=\\\"true\\\"\\u003e\\n    \\u003cspan class=\\\"ib-beam ib-beam-l\\\"\\u003e\\u003c/span\\u003e\\n    \\u003cspan class=\\\"ib-beam ib-beam-l ib-beam-l2\\\"\\u003e\\u003c/span\\u003e\\n    \\u003cspan class=\\\"ib-beam ib-beam-r\\\"\\u003e\\u003c/span\\u003e\\n    \\u003cspan class=\\\"ib-beam ib-beam-r ib-beam-r2\\\"\\u003e\\u003c/span\\u003e\\n    \\u003cdiv class=\\\"ib-grain\\\"\\u003e\\u003c/div\\u003e\\n  \\u003c/div\\u003e\\n  \\u003cdiv class=\\\"container\\\"\\u003e\\n    \\u003cdiv class=\\\"insights-inner reveal\\\"\\u003e\\n      \\u003cspan class=\\\"ib-eyebrow\\\"\\u003eInsights da Indústria\\u003c/span\\u003e\\n      \\u003ch2 class=\\\"ib-title\\\"\\u003eCada segundo extra \\u003cem\\u003ecusta-te\\u003c/em\\u003e clientes\\u003c/h2\\u003e\\n      \\u003cp class=\\\"ib-sub\\\"\\u003eDados independentes mostram que performance e design impactam diretamente a conversão e retenção. É por isso que entregamos PageSpeed 95+ por defeito.\\u003c/p\\u003e\\n\\n      \\u003cul style=\\\"list-style:none;padding:0;margin:28px auto 32px;max-width:820px;display:grid;grid-template-columns:repeat(auto-fit,minmax(220px,1fr));gap:18px;text-align:left\\\"\\u003e\\n        \\u003cli style=\\\"padding:18px 20px;border-radius:14px;border:1px solid var(--line-2);background:rgba(255,255,255,.03)\\\"\\u003e\\n          \\u003cstrong style=\\\"display:block;font-size:28px;font-weight:800;color:#fff;letter-spacing:-.02em\\\"\\u003e88%\\u003c/strong\\u003e\\n          \\u003cspan style=\\\"display:block;font-size:13.5px;color:var(--muted);line-height:1.55;margin-top:6px\\\"\\u003edos consumidores não voltam a um site após uma má experiência (\\u003ca href=\\\"https://www.amazonaws.cn/en/forrester-uxd-tech/\\\" rel=\\\"nofollow noopener\\\" target=\\\"_blank\\\" style=\\\"color:#a78bfa;text-decoration:underline\\\"\\u003eForrester via AWS\\u003c/a\\u003e)\\u003c/span\\u003e\\n        \\u003c/li\\u003e\\n        \\u003cli style=\\\"padding:18px 20px;border-radius:14px;border:1px solid var(--line-2);background:rgba(255,255,255,.03)\\\"\\u003e\\n          \\u003cstrong style=\\\"display:block;font-size:28px;font-weight:800;color:#fff;letter-spacing:-.02em\\\"\\u003e+32%\\u003c/strong\\u003e\\n          \\u003cspan style=\\\"display:block;font-size:13.5px;color:var(--muted);line-height:1.55;margin-top:6px\\\"\\u003eprobabilidade de bounce quando uma página demora 3s em vez de 1s a carregar (\\u003ca href=\\\"https://www.thinkwithgoogle.com/marketing-strategies/app-and-mobile/page-load-time-statistics/\\\" rel=\\\"nofollow noopener\\\" target=\\\"_blank\\\" style=\\\"color:#a78bfa;text-decoration:underline\\\"\\u003eGoogle / Think with Google\\u003c/a\\u003e)\\u003c/span\\u003e\\n        \\u003c/li\\u003e\\n        \\u003cli style=\\\"padding:18px 20px;border-radius:14px;border:1px solid var(--line-2);background:rgba(255,255,255,.03)\\\"\\u003e\\n          \\u003cstrong style=\\\"display:block;font-size:28px;font-weight:800;color:#fff;letter-spacing:-.02em\\\"\\u003e75%\\u003c/strong\\u003e\\n          \\u003cspan style=\\\"display:block;font-size:13.5px;color:var(--muted);line-height:1.55;margin-top:6px\\\"\\u003edos utilizadores avaliam a credibilidade de um negócio com base no design do website (\\u003ca href=\\\"https://www.researchgate.net/publication/220371405_The_role_of_design_in_the_credibility_of_e-commerce_websites\\\" rel=\\\"nofollow noopener\\\" target=\\\"_blank\\\" style=\\\"color:#a78bfa;text-decoration:underline\\\"\\u003eStanford Web Credibility Research\\u003c/a\\u003e)\\u003c/span\\u003e\\n        \\u003c/li\\u003e\\n      \\u003c/ul\\u003e\\n\\n      \\u003ca class=\\\"btn-primary ib-btn\\\" href=\\\"/contacto\\\"\\u003eIniciar Projeto \\u003csvg width=\\\"14\\\" height=\\\"14\\\" viewBox=\\\"0 0 24 24\\\" fill=\\\"none\\\" stroke=\\\"currentColor\\\" stroke-width=\\\"2.4\\\"\\u003e\\u003cpath d=\\\"M7 17L17 7M9 7h8v8\\\"/\\u003e\\u003c/svg\\u003e\\u003c/a\\u003e\\n    \\u003c/div\\u003e\\n  \\u003c/div\\u003e\\n\\u003c/section\\u003e\\n\\n\\u003c!-- ========= TESTEMUNHOS ========= --\\u003e\\n\\u003csection id=\\\"testemunhos\\\" class=\\\"has-atmos atmos-pro\\\"\\u003e\\n  \\u003cdiv class=\\\"atmos-rays\\\" aria-hidden=\\\"true\\\"\\u003e\\u003c/div\\u003e\\n  \\u003cdiv class=\\\"section-atmos\\\" aria-hidden=\\\"true\\\"\\u003e\\n    \\u003cdiv class=\\\"rings\\\"\\u003e\\u003cspan\\u003e\\u003c/span\\u003e\\u003cspan\\u003e\\u003c/span\\u003e\\u003cspan\\u003e\\u003c/span\\u003e\\u003cspan\\u003e\\u003c/span\\u003e\\u003cspan\\u003e\\u003c/span\\u003e\\u003cspan\\u003e\\u003c/span\\u003e\\u003c/div\\u003e\\n    \\u003cdiv class=\\\"section-sparkles\\\"\\u003e\\n      \\u003cspan style=\\\"left:18%;top:80px;animation-delay:1.0s\\\"\\u003e\\u003c/span\\u003e\\n      \\u003cspan style=\\\"left:32%;top:200px;animation-delay:.5s\\\"\\u003e\\u003c/span\\u003e\\n      \\u003cspan style=\\\"left:48%;top:60px;animation-delay:2.2s\\\"\\u003e\\u003c/span\\u003e\\n      \\u003cspan style=\\\"left:62%;top:170px;animation-delay:1.4s\\\"\\u003e\\u003c/span\\u003e\\n      \\u003cspan style=\\\"left:78%;top:90px;animation-delay:.8s\\\"\\u003e\\u003c/span\\u003e\\n    \\u003c/div\\u003e\\n  \\u003c/div\\u003e\\n  \\u003cdiv class=\\\"container\\\"\\u003e\\n    \\u003cdiv class=\\\"section-head reveal\\\"\\u003e\\n      \\u003cspan class=\\\"eyebrow\\\"\\u003eTestemunhos\\u003c/span\\u003e\\n      \\u003ch2 class=\\\"section-title\\\"\\u003eHistórias de \\u003cem\\u003esucesso\\u003c/em\\u003e dos clientes\\u003c/h2\\u003e\\n      \\u003cp class=\\\"section-sub\\\"\\u003eDescobre o que os nossos clientes dizem sobre as suas experiências e sucesso a trabalhar connosco.\\u003c/p\\u003e\\n    \\u003c/div\\u003e\\n    \\u003cdiv class=\\\"tx-wrap reveal\\\"\\u003e\\n      \\u003cbutton class=\\\"tx-arc tx-arc-l\\\" aria-hidden=\\\"true\\\"\\u003e\\u003c/button\\u003e\\n      \\u003cbutton class=\\\"tx-arc tx-arc-r\\\" aria-hidden=\\\"true\\\"\\u003e\\u003c/button\\u003e\\n      \\u003cdiv class=\\\"tx-stage\\\"\\u003e\\n        \\u003carticle class=\\\"tx-card\\\" data-i=\\\"0\\\"\\u003e\\n        \\u003cdiv class=\\\"tx-bar\\\"\\u003e\\u003c/div\\u003e\\n        \\u003csvg class=\\\"tx-quote\\\" width=\\\"42\\\" height=\\\"34\\\" viewBox=\\\"0 0 38 32\\\" fill=\\\"currentColor\\\"\\u003e\\u003cpath d=\\\"M0 18C0 8 6 2 16 0v6c-5 1-8 5-8 10h8v16H0V18zm22 0c0-10 6-16 16-18v6c-5 1-8 5-8 10h8v16H22V18z\\\"/\\u003e\\u003c/svg\\u003e\\n        \\u003cp class=\\\"tx-text\\\"\\u003eRecomendo totalmente o trabalho realizado na criação do meu site. Destaco o profissionalismo, a rapidez na execução e a excelente capacidade de transformar ideias em processos claros, simples e eficazes. Todo o desenvolvimento foi conduzido com grande organização, comunicação eficiente e foco na solução. O tratamento do projeto foi exemplar, com elevada qualidade técnica e prazos cumpridos de forma impressionante. Uma escolha segura para quem procura eficiência, rigor e resultados.\\u003c/p\\u003e\\n        \\u003cdiv class=\\\"tx-stars\\\"\\u003e\\u003cspan\\u003e\\u003c/span\\u003e\\u003cspan\\u003e\\u003c/span\\u003e\\u003cspan\\u003e\\u003c/span\\u003e\\u003cspan\\u003e\\u003c/span\\u003e\\u003cspan\\u003e\\u003c/span\\u003e\\u003c/div\\u003e\\n        \\u003cdiv class=\\\"tx-author\\\"\\u003e\\n          \\u003cdiv class=\\\"tx-av has-photo\\\" data-i=\\\"RJ\\\"\\u003e\\u003cimg src=\\\"https://ctflpbjvsepkbfjpgkuh.supabase.co/storage/v1/object/public/review-avatars/ricardo-jesus.png\\\" alt=\\\"Ricardo Jesus\\\" loading=\\\"lazy\\\" decoding=\\\"async\\\"/\\u003e\\u003c/div\\u003e\\n          \\u003cdiv\\u003e\\u003cb\\u003eRicardo Jesus\\u003c/b\\u003e\\u003csmall\\u003eCEO · Apiários Terras da Pulga\\u003c/small\\u003e\\u003c/div\\u003e\\n        \\u003c/div\\u003e\\n      \\u003c/article\\u003e\\n\\u003carticle class=\\\"tx-card\\\" data-i=\\\"1\\\"\\u003e\\n        \\u003cdiv class=\\\"tx-bar\\\"\\u003e\\u003c/div\\u003e\\n        \\u003csvg class=\\\"tx-quote\\\" width=\\\"42\\\" height=\\\"34\\\" viewBox=\\\"0 0 38 32\\\" fill=\\\"currentColor\\\"\\u003e\\u003cpath d=\\\"M0 18C0 8 6 2 16 0v6c-5 1-8 5-8 10h8v16H0V18zm22 0c0-10 6-16 16-18v6c-5 1-8 5-8 10h8v16H22V18z\\\"/\\u003e\\u003c/svg\\u003e\\n        \\u003cp class=\\\"tx-text\\\"\\u003eExcelente profissional, bastante atencioso, simpático e empenhado