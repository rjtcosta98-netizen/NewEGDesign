-4 3.9.94 5.46L12 14.77 7.06 17.36 8 11.9 4 8l5.61-1.16L12 2z\"/></svg></span>Identidade Visual</div>\n        <div class=\"chip\"><span class=\"ci\"><svg width=\"18\" height=\"18\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2\"><path d=\"M21 15a4 4 0 0 1-4 4H8l-5 3V6a4 4 0 0 1 4-4h10a4 4 0 0 1 4 4z\"/></svg></span>Copywriting</div>\n        <div class=\"chip\"><span class=\"ci\"><svg width=\"18\" height=\"18\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2\"><path d=\"M4 4h16v12H4zM2 20h20\"/></svg></span>Manutenção &amp; Apoio</div>\n        <div class=\"chip\"><span class=\"ci\"><svg width=\"18\" height=\"18\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2\"><path d=\"M12 2v20M2 12h20\"/></svg></span>Integrações &amp; APIs</div>\n\n        <!-- duplicado para loop sem corte -->\n        <div class=\"chip\"><span class=\"ci\"><svg width=\"18\" height=\"18\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2\"><path d=\"M3 7h18M3 12h18M3 17h12\"/></svg></span>Web Design</div>\n        <div class=\"chip\"><span class=\"ci\"><svg width=\"18\" height=\"18\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2\"><circle cx=\"12\" cy=\"12\" r=\"4\"/><circle cx=\"12\" cy=\"12\" r=\"9\"/></svg></span>Logo &amp; Branding</div>\n        <div class=\"chip\"><span class=\"ci\"><svg width=\"18\" height=\"18\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2\"><rect x=\"3\" y=\"3\" width=\"18\" height=\"18\" rx=\"4\"/><circle cx=\"12\" cy=\"12\" r=\"4\"/></svg></span>Posts Redes Sociais</div>\n        <div class=\"chip\"><span class=\"ci\"><svg width=\"18\" height=\"18\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2\"><circle cx=\"11\" cy=\"11\" r=\"7\"/><path d=\"M21 21l-4.3-4.3\"/></svg></span>SEO Local</div>\n        <div class=\"chip\"><span class=\"ci\"><svg width=\"18\" height=\"18\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2\"><path d=\"M3 9l1.5-5h15L21 9M3 9v11a1 1 0 0 0 1 1h16a1 1 0 0 0 1-1V9M3 9h18M9 13a3 3 0 0 0 6 0\"/></svg></span>Loja Online</div>\n        <div class=\"chip\"><span class=\"ci\"><svg width=\"18\" height=\"18\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2\"><rect x=\"6\" y=\"2\" width=\"12\" height=\"20\" rx=\"3\"/><path d=\"M11 18h2\"/></svg></span>Apps Mobile</div>\n        <div class=\"chip\"><span class=\"ci\"><svg width=\"18\" height=\"18\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2\"><path d=\"M3 12h4l3-9 4 18 3-9h4\"/></svg></span>Marketing Digital</div>\n        <div class=\"chip\"><span class=\"ci\"><svg width=\"18\" height=\"18\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2\"><path d=\"M4 4h16v6H4zM4 14h10v6H4z\"/></svg></span>Design Gráfico</div>\n        <div class=\"chip\"><span class=\"ci\"><svg width=\"18\" height=\"18\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2\"><path d=\"M12 2l2.39 4.84L20 8l-4 3.9.94 5.46L12 14.77 7.06 17.36 8 11.9 4 8l5.61-1.16L12 2z\"/></svg></span>Identidade Visual</div>\n        <div class=\"chip\"><span class=\"ci\"><svg width=\"18\" height=\"18\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2\"><path d=\"M21 15a4 4 0 0 1-4 4H8l-5 3V6a4 4 0 0 1 4-4h10a4 4 0 0 1 4 4z\"/></svg></span>Copywriting</div>\n        <div class=\"chip\"><span class=\"ci\"><svg width=\"18\" height=\"18\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2\"><path d=\"M4 4h16v12H4zM2 20h20\"/></svg></span>Manutenção &amp; Apoio</div>\n        <div class=\"chip\"><span class=\"ci\"><svg width=\"18\" height=\"18\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2\"><path d=\"M12 2v20M2 12h20\"/></svg></span>Integrações &amp; APIs</div>\n      </div>\n    </div>\n  </div>\n</section>\n\n<!-- ========= PROCESSO ========= -->\n<section id=\"processo\">\n  <div class=\"section-atmos\" aria-hidden=\"true\">\n    <div class=\"rings\"><span></span><span></span><span></span><span></span><span></span><span></span></div>\n    <div class=\"section-sparkles\">\n      <span style=\"left:18%;top:70px;animation-delay:1.1s\"></span>\n      <span style=\"left:28%;top:170px;animation-delay:.4s\"></span>\n      <span style=\"left:36%;top:50px;animation-delay:3.0s\"></span>\n      <span style=\"left:46%;top:130px;animation-delay:1.8s\"></span>\n      <span style=\"left:54%;top:210px;animation-delay:.9s\"></span>\n      <span style=\"left:62%;top:80px;animation-delay:2.5s\"></span>\n      <span style=\"left:70%;top:150px;animation-delay:1.3s\"></span>\n      <span style=\"left:78%;top:90px;animation-delay:2.8s\"></span>\n      <span style=\"left:84%;top:230px;animation-delay:.5s\"></span>\n    </div>\n  </div>\n  <div class=\"container\">\n    <div class=\"section-head reveal\">\n      <span class=\"eyebrow\">Processo</span>\n      <h2 class=\"section-title\">Como <em>trabalhamos</em></h2>\n      <p class=\"section-sub\">Um método claro e eficiente, do primeiro contacto à entrega final do projeto.</p>\n    </div>\n    <div class=\"steps\">\n      <div class=\"step reveal\">\n        <div class=\"num\">01</div>\n        <div class=\"icon\"><svg width=\"20\" height=\"20\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"1.7\"><circle cx=\"11\" cy=\"11\" r=\"7\"/><path d=\"M21 21l-4.3-4.3\"/></svg></div>\n        <h4>Descoberta</h4>\n        <p>Conhecemos o teu negócio, objetivos e público-alvo para definirmos o âmbito.</p>\n      </div>\n      <div class=\"step reveal\">\n        <div class=\"num\">02</div>\n        <div class=\"icon\"><svg width=\"20\" height=\"20\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"1.7\"><path d=\"M3 17l6-6 4 4 8-8\"/></svg></div>\n        <h4>Conceito</h4>\n        <p>Apresentamos uma proposta visual e estratégica alinhada com a tua marca.</p>\n      </div>\n      <div class=\"step reveal\">\n        <div class=\"num\">03</div>\n        <div class=\"icon\"><svg width=\"20\" height=\"20\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"1.7\"><polyline points=\"16 18 22 12 16 6\"/><polyline points=\"8 6 2 12 8 18\"/></svg></div>\n        <h4>Desenvolvimento</h4>\n        <p>Construímos e testamos o projeto, garantindo performance e compatibilidade.</p>\n      </div>\n      <div class=\"step reveal\">\n        <div class=\"num\">04</div>\n        <div class=\"icon\"><svg width=\"20\" height=\"20\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"1.7\"><path d=\"M5 12l4 4L19 6\"/></svg></div>\n        <h4>Lançamento &amp; Apoio</h4>\n        <p>Colocamos online e ficamos disponíveis para apoio contínuo a longo prazo.</p>\n      </div>\n    </div>\n  </div>\n</section>\n\n<!-- ========= FUNCIONALIDADES-CHAVE (Key Features Overview) ========= -->\n<section id=\"funcionalidades\" class=\"has-atmos\">\n  <div class=\"section-atmos\" aria-hidden=\"true\">\n    <div class=\"rings\"><span></span><span></span><span></span><span></span><span></span><span></span></div>\n    <div class=\"section-sparkles\">\n      <span style=\"left:14%;top:90px;animation-delay:1.2s\"></span>\n      <span style=\"left:26%;top:200px;animation-delay:.5s\"></span>\n      <span style=\"left:40%;top:60px;animation-delay:2.4s\"></span>\n      <span style=\"left:58%;top:170px;animation-delay:1.6s\"></span>\n      <span style=\"left:72%;top:90px;animation-delay:.8s\"></span>\n      <span style=\"left:84%;top:220px;animation-delay:2.1s\"></span>\n    </div>\n  </div>\n  <div class=\"container\">\n    <div class=\"section-head reveal\">\n      <span class=\"eyebrow\">Funcionalidades-chave</span>\n      <h2 class=\"section-title\">Tudo o que precisas, <em>incluído</em></h2>\n      <p class=\"section-sub\">Cada projeto vem equipado com as funcionalidades essenciais para crescer online — sem custos escondidos.</p>\n    </div>\n    <div class=\"kf-grid reveal\">\n      <article class=\"kf-card kf-big\">\n        <div class=\"kf-glow\"></div>\n        <div class=\"kf-pill\"><span></span> Em destaque</div>\n        <h3>Performance <em>extrema</em></h3>\n        <p>Sites otimizados que carregam em menos de <b>1.5 segundos</b>. Pontuação PageSpeed acima de 95 — em mobile e desktop. Os utilizadores não esperam, e o Google premeia.</p>\n        <div class=\"kf-metric\">\n          <div class=\"kf-num\">95<small>+</small></div>\n          <div class=\"kf-meter\"><span style=\"--w:96%\"></span></div>\n          <div class=\"kf-meta\">Pontuação PageSpeed média</div>\n        </div>\n      </article>\n      <article class=\"kf-card\">\n        <div class=\"kf-ic\"><svg width=\"22\" height=\"22\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"1.7\"><path d=\"M12 2v20M2 12h20\"/><circle cx=\"12\" cy=\"12\" r=\"9\"/></svg></div>\n        <h4>SEO técnico</h4>\n        <p>Estrutura semântica, schema.org, sitemap automático e meta-tags otimizadas em todas as páginas.</p>\n      </article>\n      <article class=\"kf-card\">\n        <div class=\"kf-ic\"><svg width=\"22\" height=\"22\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"1.7\"><rect x=\"3\" y=\"4\" width=\"18\" height=\"14\" rx=\"2\"/><path d=\"M3 10h18M8 4v14\"/></svg></div>\n        <h4>Painel de gestão</h4>\n        <p>Edita conteúdos, imagens e produtos sem mexer em código. Interface simples em português.</p>\n      </article>\n      <article class=\"kf-card\">\n        <div class=\"kf-ic\"><svg width=\"22\" height=\"22\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"1.7\"><path d=\"M12 22s8-4 8-12V5l-8-3-8 3v5c0 8 8 12 8 12z\"/></svg></div>\n        <h4>SSL &amp; segurança</h4>\n        <p>Certificado HTTPS incluído, backups diários e proteção contra ataques. Tranquilidade total.</p>\n      </article>\n      <article class=\"kf-card\">\n        <div class=\"kf-ic\"><svg width=\"22\" height=\"22\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"1.7\"><rect x=\"5\" y=\"2\" width=\"14\" height=\"20\" rx=\"3\"/><path d=\"M11 18h2\"/></svg></div>\n        <h4>100% Responsivo</h4>\n        <p>Experiência impecável em telemóvel, tablet, portátil e ecrã grande. Testado em 30+ dispositivos.</p>\n      </article>\n      <article class=\"kf-card\">\n        <div class=\"kf-ic\"><svg width=\"22\" height=\"22\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"1.7\"><path d=\"M3 12a9 9 0 1 0 9-9\"/><path d=\"M3 4v8h8\"/></svg></div>\n        <h4>Atualizações contínuas</h4>\n        <p>Manutenção, melhorias de segurança e novos features sempre disponíveis a um clique.</p>\n      </article>\n    </div>\n  </div>\n</section>\n\n<!-- ========= RESULTADOS &amp; ANALYTICS ========= -->\n<section id=\"resultados\" class=\"has-atmos\">\n  <div class=\"section-atmos\" aria-hidden=\"true\">\n    <div class=\"rings\"></div>\n    <div class=\"section-sparkles\">\n      <span style=\"left:12%;top:90px;animation-delay:1.0s\"></span>\n      <span style=\"left:22%;top:200px;animation-delay:.4s\"></span>\n      <span style=\"left:34%;top:60px;animation-delay:2.2s\"></span>\n      <span style=\"left:46%;top:160px;animation-delay:1.5s\"></span>\n      <span style=\"left:56%;top:80px;animation-delay:.8s\"></span>\n      <span style=\"left:68%;top:190px;animation-delay:2.6s\"></span>\n      <span style=\"left:80%;top:110px;animation-delay:1.2s\"></span>\n      <span style=\"left:88%;top:60px;animation-delay:.5s\"></span>\n    </div>\n  </div>\n  <div class=\"container\">\n    <div class=\"section-head reveal\">\n      <span class=\"eyebrow\">Resultados</span>\n      <h2 class=\"section-title\">Números que <em>falam</em> por nós</h2>\n      <p class=\"section-sub\">Mais do que websites bonitos — entregamos performance mensurável que se traduz em vendas e visibilidade.</p>\n    </div>\n    <div class=\"res-grid\">\n      <div class=\"res-stats reveal\">\n        <div class=\"res-stat\">\n          <div class=\"res-num\"><span class=\"ct\" data-to=\"120\">0</span><i>+</i></div>\n          <div class=\"res-label\">Projetos entregues</div>\n        </div>\n        <div class=\"res-stat\">\n          <div class=\"res-num\"><span class=\"ct\" data-to=\"98\">0</span><i>%</i></div>\n          <div class=\"res-label\">Clientes satisfeitos</div>\n        </div>\n        <div class=\"res-stat\">\n          <div class=\"res-num\"><span class=\"ct\" data-to=\"3.2\" data-dec=\"1\">0</span><i>x</i></div>\n          <div class=\"res-label\">Aumento médio de tráfego</div>\n        </div>\n        <div class=\"res-stat\">\n          <div class=\"res-num\"><span class=\"ct\" data-to=\"48\">0</span><i>h</i></div>\n          <div class=\"res-label\">Tempo médio de resposta</div>\n        </div>\n      </div>\n      <div class=\"res-chart reveal\" aria-label=\"Gráfico de crescimento de tráfego ao longo de 8 meses\">\n        <div class=\"rc-head\">\n          <div>\n            <div class=\"rc-eyebrow\">Caso real — loja de moda</div>\n            <h3 class=\"rc-title\">+318% tráfego orgânico</h3>\n          </div>\n          <div class=\"rc-tag\">8 meses</div>\n        </div>\n        <div class=\"rc-grid\">\n          <div class=\"rc-bars\">\n            <div class=\"rc-bar\" style=\"--h:18%\" data-m=\"Jan\"><span></span></div>\n            <div class=\"rc-bar\" style=\"--h:24%\" data-m=\"Fev\"><span></span></div>\n            <div class=\"rc-bar\" style=\"--h:32%\" data-m=\"Mar\"><span></span></div>\n            <div class=\"rc-bar\" style=\"--h:42%\" data-m=\"Abr\"><span></span></div>\n            <div class=\"rc-bar\" style=\"--h:55%\" data-m=\"Mai\"><span></span></div>\n            <div class=\"rc-bar\" style=\"--h:68%\" data-m=\"Jun\"><span></span></div>\n            <div class=\"rc-bar\" style=\"--h:82%\" data-m=\"Jul\"><span></span></div>\n            <div class=\"rc-bar rc-bar-active\" style=\"--h:96%\" data-m=\"Ago\"><span></span></div>\n          </div>\n          <svg class=\"rc-line\" viewBox=\"0 0 320 160\" preserveAspectRatio=\"none\">\n            <defs>\n              <linearGradient id=\"rcg\" x1=\"0\" x2=\"0\" y1=\"0\" y2=\"1\">\n                <stop offset=\"0%\" stop-color=\"#a78bfa\" stop-opacity=\".5\"/>\n                <stop offset=\"100%\" stop-color=\"#a78bfa\" stop-opacity=\"0\"/>\n              </linearGradient>\n            </defs>\n            <path d=\"M0,131 L40,121 L80,109 L120,93 L160,73 L200,52 L240,29 L280,11 L320,5 L320,160 L0,160 Z\" fill=\"url(#rcg)\"/>\n            <path d=\"M0,131 L40,121 L80,109 L120,93 L160,73 L200,52 L240,29 L280,11 L320,5\" fill=\"none\" stroke=\"#c0a8ff\" stroke-width=\"2.2\" stroke-linecap=\"round\" stroke-linejoin=\"round\"/>\n          </svg>\n        </div>\n        <div class=\"rc-foot\">\n          <div class=\"rc-kpi\"><b>+318%</b><small>tráfego orgânico</small></div>\n          <div class=\"rc-kpi\"><b>+212%</b><small>conversões</small></div>\n          <div class=\"rc-kpi\"><b>0,9s</b><small>LCP final</small></div>\n        </div>\n      </div>\n    </div>\n  </div>\n</section>\n\n<!-- ========= TECNOLOGIAS ========= -->\n<section id=\"tecnologias\" class=\"has-atmos atmos-pro\">\n  <div class=\"atmos-rays\" aria-hidden=\"true\"></div>\n  <div class=\"section-atmos\" aria-hidden=\"true\">\n    <div class=\"rings\"><span></span><span></span><span></span><span></span><span></span><span></span></div>\n    <div class=\"section-sparkles\">\n      <span style=\"left:14%;top:90px;animation-delay:1.0s\"></span>\n      <span style=\"left:30%;top:180px;animation-delay:.4s\"></span>\n      <span style=\"left:48%;top:50px;animation-delay:2.4s\"></span>\n      <span style=\"left:64%;top:160px;animation-delay:1.7s\"></span>\n      <span style=\"left:80%;top:90px;animation-delay:.7s\"></span>\n    </div>\n  </div>\n  <div class=\"container\">\n    <div class=\"section-head reveal\">\n      <span class=\"eyebrow\">Tecnologias</span>\n      <div class=\"tools-pill reveal\" aria-hidden=\"true\">\n        <span class=\"tp-ic tp-ic-1\"></span>\n        <span class=\"tp-ic tp-ic-2\"></span>\n        <span class=\"tp-ic tp-ic-3\"></span>\n        <span class=\"tp-ic tp-ic-4\"></span>\n      </div>\n      <h2 class=\"section-title\">Ferramentas que usamos para a <em>excelência</em></h2>\n      <p class=\"section-sub\">Conhece as tecnologias avançadas que utilizamos para criar websites de última geração.</p>\n    </div>\n    <div class=\"tools-grid reveal\">\n      <a class=\"tool-card\" href=\"#\" data-tc=\"violet\">\n        <span class=\"tc-ic\"><svg width=\"22\" height=\"22\" viewBox=\"0 0 24 24\" fill=\"currentColor\"><path d=\"M12 2L2 8l10 6 10-6-10-6zm0 8.5L4.3 6 12 1.5 19.7 6 12 10.5zM2 16l10 6 10-6m-20-4l10 6 10-6\"/></svg></span>\n        <span class=\"tc-name\">Next.js</span>\n        <span class=\"tc-arrow\"><svg width=\"14\" height=\"14\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2\"><path d=\"M7 17L17 7M9 7h8v8\"/></svg></span>\n        <p class=\"tc-desc\">Framework React de produção com performance extrema.</p>\n      </a>\n      <a class=\"tool-card\" href=\"#\" data-tc=\"orange\">\n        <span class=\"tc-ic\"><svg width=\"22\" height=\"22\" viewBox=\"0 0 24 24\" fill=\"currentColor\"><circle cx=\"12\" cy=\"12\" r=\"10\"/><path d=\"M12 8v8M8 12h8\" stroke=\"#0c1224\" stroke-width=\"2\"/></svg></span>\n        <span class=\"tc-name\">Figma</span>\n        <span class=\"tc-arrow\"><svg width=\"14\" height=\"14\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2\"><path d=\"M7 17L17 7M9 7h8v8\"/></svg></span>\n        <p class=\"tc-desc\">Design colaborativo e prototipagem em tempo real.</p>\n      </a>\n      <a class=\"tool-card\" href=\"#\" data-tc=\"green\">\n        <span class=\"tc-ic\"><svg width=\"22\" height=\"22\" viewBox=\"0 0 24 24\" fill=\"currentColor\"><path d=\"M12 2l9 5v10l-9 5-9-5V7l9-5zm0 2.3L5 8v8l7 3.7 7-3.7V8l-7-3.7z\"/></svg></span>\n        <span class=\"tc-name\">Shopify</span>\n        <span class=\"tc-arrow\"><svg width=\"14\" height=\"14\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2\"><path d=\"M7 17L17 7M9 7h8v8\"/></svg></span>\n        <p class=\"tc-desc\">Plataforma e-commerce robusta para lojas online.</p>\n      </a>\n      <a class=\"tool-card\" href=\"#\" data-tc=\"red\">\n        <span class=\"tc-ic\"><svg width=\"22\" height=\"22\" viewBox=\"0 0 24 24\" fill=\"currentColor\"><path d=\"M3 3h7v7H3zm11 0h7v7h-7zM3 14h7v7H3zm14 0a3.5 3.5 0 110 7 3.5 3.5 0 010-7z\"/></svg></span>\n        <span class=\"tc-name\">WordPress</span>\n        <span class=\"tc-arrow\"><svg width=\"14\" height=\"14\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2\"><path d=\"M7 17L17 7M9 7h8v8\"/></svg></span>\n        <p class=\"tc-desc\">CMS flexível para sites institucionais e blogs.</p>\n      </a>\n      <a class=\"tool-card\" href=\"#\" data-tc=\"yellow\">\n        <span class=\"tc-ic\"><svg width=\"22\" height=\"22\" viewBox=\"0 0 24 24\" fill=\"currentColor\"><path d=\"M12 2l3 7h7l-5.5 4.5L18 22l-6-4-6 4 1.5-8.5L2 9h7z\"/></svg></span>\n        <span class=\"tc-name\">Webflow</span>\n        <span class=\"tc-arrow\"><svg width=\"14\" height=\"14\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2\"><path d=\"M7 17L17 7M9 7h8v8\"/></svg></span>\n        <p class=\"tc-desc\">Design e desenvolvimento visual sem comprometer performance.</p>\n      </a>\n      <a class=\"tool-card\" href=\"#\" data-tc=\"cyan\">\n        <span class=\"tc-ic\"><svg width=\"22\" height=\"22\" viewBox=\"0 0 24 24\" fill=\"currentColor\"><rect x=\"3\" y=\"5\" width=\"18\" height=\"14\" rx=\"2\"/><path d=\"M7 9h10v2H7zm0 4h6v2H7z\" fill=\"#0c1224\"/></svg></span>\n        <span class=\"tc-name\">Stripe</span>\n        <span class=\"tc-arrow\"><svg width=\"14\" height=\"14\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2\"><path d=\"M7 17L17 7M9 7h8v8\"/></svg></span>\n        <p class=\"tc-desc\">Processamento de pagamentos online seguro e fiável.</p>\n      </a>\n    </div>\n  </div>\n</section>\n\n<!-- ========= TRABALHOS / WORKS ========= -->\n<section id=\"trabalhos\" class=\"has-atmos\">\n  <div class=\"section-atmos\" aria-hidden=\"true\">\n    <div class=\"rings\"><span></span><span></span><span></span><span></span><span></span><span></span></div>\n    <div class=\"section-sparkles\">\n      <span style=\"left:12%;top:100px;animation-delay:1.0s\"></span>\n      <span style=\"left:30%;top:200px;animation-delay:.3s\"></span>\n      <span style=\"left:48%;top:60px;animation-delay:2.2s\"></span>\n      <span style=\"left:64%;top:170px;animation-delay:1.4s\"></span>\n      <span style=\"left:80%;top:90px;animation-delay:.7s\"></span>\n    </div>\n  </div>\n  <div class=\"container\">\n    <div class=\"section-head reveal\">\n      <span class=\"eyebrow\">Projetos</span>\n      <h2 class=\"section-title\">Projetos <em>recentes</em></h2>\n      <p class=\"section-sub\">Uma seleção de websites, lojas e campanhas que entregámos para clientes em Portugal e além-fronteiras.</p>\n    </div>\n    <div class=\"wk-grid\"><a class=\"wk-card reveal\" href=\"https://www.apiariosterrasdapulga.pt/\" data-color=\"violet\" target=\"_blank\" rel=\"noopener noreferrer\">\n        <div class=\"wk-thumb\">\n          <div class=\"wk-mock\">\n            <div class=\"wk-bar\"><i></i><i></i><i></i></div>\n            <div class=\"wk-screen wk-screen-1\">\n              <div class=\"wks-nav\"><b>Apiários Terras da Pulga</b><span></span><span></span><span></span></div>\n              <div style=\"position:relative;flex:1;min-height:160px;border-radius:8px;overflow:hidden;border:1px solid var(--line)\"><img src=\"https://ctflpbjvsepkbfjpgkuh.supabase.co/storage/v1/object/public/project-images/apiarios-projeto.webp\n\n\" alt=\"Apiários Terras da Pulga\" loading=\"lazy\" decoding=\"async\" style=\"position:absolute;inset:0;width:100%;height:100%;object-fit:cover\"/></div>\n            </div>\n          </div>\n        </div>\n        <div class=\"wk-meta\">\n          <div class=\"wk-titles\">\n            <h3>Apiários Terras da Pulga</h3>\n            <p>Loja online para venda de mel e produtos apícolas com checkout MBWay e Multibanco.</p>\n          </div>\n          <span class=\"wk-tag\">website</span>\n        </div>\n      </a><a class=\"wk-card reveal\" href=\"https://mariamendesmassagens.pt/\" data-color=\"green\" target=\"_blank\" rel=\"noopener noreferrer\">\n        <div class=\"wk-thumb\">\n          <div class=\"wk-mock\">\n            <div class=\"wk-bar\"><i></i><i></i><i></i></div>\n            <div class=\"wk-screen wk-screen-1\">\n              <div class=\"wks-nav\"><b>Maria Mendes Massagens</b><span></span><span></span><span></span></div>\n              <div style=\"position:relative;flex:1;min-height:160px;border-radius:8px;overflow:hidden;border:1px solid var(--line)\"><img src=\"https://ctflpbjvsepkbfjpgkuh.supabase.co/storage/v1/object/public/project-images/maria-mendes-projeto.webp\n\n\n\" alt=\"Maria Mendes Massagens\" loading=\"lazy\" decoding=\"async\" style=\"position:absolute;inset:0;width:100%;height:100%;object-fit:cover\"/></div>\n            </div>\n          </div>\n        </div>\n        <div class=\"wk-meta\">\n          <div class=\"wk-titles\">\n            <h3>Maria Mendes Massagens</h3>\n            <p>Website com sistema de marcações online para centro de massagens terapêuticas.</p>\n          </div>\n          <span class=\"wk-tag\">website</span>\n        </div>\n      </a><a class=\"wk-card reveal\" href=\"https://adsaoromao.pt/\" data-color=\"cyan\" target=\"_blank\" rel=\"noopener noreferrer\">\n        <div class=\"wk-thumb\">\n          <div class=\"wk-mock\">\n            <div class=\"wk-bar\"><i></i><i></i><i></i></div>\n            <div class=\"wk-screen wk-screen-1\">\n              <div class=\"wks-nav\"><b>AD São Romão</b><span></span><span></span><span></span></div>\n              <div style=\"position:relative;flex:1;min-height:160px;border-radius:8px;overflow:hidden;border:1px solid var(--line)\"><img src=\"https://ctflpbjvsepkbfjpgkuh.supabase.co/storage/v1/object/public/project-images/adsr-projeto.webp\n\n\n\" alt=\"AD São Romão\" loading=\"lazy\" decoding=\"async\" style=\"position:absolute;inset:0;width:100%;height:100%;object-fit:cover\"/></div>\n            </div>\n          </div>\n        </div>\n        <div class=\"wk-meta\">\n          <div class=\"wk-titles\">\n            <h3>AD São Romão</h3>\n            <p>Website institucional para associação desportiva local com calendário de jogos e notícias.</p>\n          </div>\n          <span class=\"wk-tag\">website</span>\n        </div>\n      </a><a class=\"wk-card reveal\" href=\"https://www.facebook.com/profile.php?id=61573358033960\" data-color=\"yellow\" target=\"_blank\" rel=\"noopener noreferrer\">\n        <div class=\"wk-thumb\">\n          <div class=\"wk-mock\">\n            <div class=\"wk-bar\"><i></i><i></i><i></i></div>\n            <div class=\"wk-screen wk-screen-1\">\n              <div class=\"wks-nav\"><b>Estrela Detail &amp; Wash</b><span></span><span></span><span></span></div>\n              <div style=\"position:relative;flex:1;min-height:160px;border-radius:8px;overflow:hidden;border:1px solid var(--line)\"><img src=\"https://ctflpbjvsepkbfjpgkuh.supabase.co/storage/v1/object/public/project-images/estrela-branding.webp\" alt=\"Estrela Detail &amp; Wash\" loading=\"lazy\" decoding=\"async\" style=\"position:absolute;inset:0;width:100%;height:100%;object-fit:cover\"/></div>\n            </div>\n          </div>\n        </div>\n        <div class=\"wk-meta\">\n          <div class=\"wk-titles\">\n            <h3>Estrela Detail &amp; Wash</h3>\n            <p>Website profissional para serviço de detailing e lavagem automóvel com marcações online.</p>\n          </div>\n          <span class=\"wk-tag\">branding</span>\n        </div>\n      </a><a class=\"wk-card reveal\" href=\"https://www.footballnationstore.pt/\" data-color=\"violet\" target=\"_blank\" rel=\"noopener noreferrer\">\n        <div class=\"wk-thumb\">\n          <div class=\"wk-mock\">\n            <div class=\"wk-bar\"><i></i><i></i><i></i></div>\n            <div class=\"wk-screen wk-screen-1\">\n              <div class=\"wks-nav\"><b>Football Nation Store — Branding</b><span></span><span></span><span></span></div>\n              <div style=\"position:relative;flex:1;min-height:160px;border-radius:8px;overflow:hidden;border:1px solid var(--line)\"><img src=\"https://ctflpbjvsepkbfjpgkuh.supabase.co/storage/v1/object/public/project-images/football-design-projeto.webp\n\n\" alt=\"Football Nation Store — Branding\" loading=\"lazy\" decoding=\"async\" style=\"position:absolute;inset:0;width:100%;height:100%;object-fit:cover\"/></div>\n            </div>\n          </div>\n        </div>\n        <div class=\"wk-meta\">\n          <div class=\"wk-titles\">\n            <h3>Football Nation Store — Branding</h3>\n            <p>Logótipo e cartão de visita profissional para e-commerce de camisolas de clubes.</p>\n          </div>\n          <span class=\"wk-tag\">branding</span>\n        </div>\n      </a><a class=\"wk-card reveal\" href=\"https://matiasnature.com\" data-color=\"green\" target=\"_blank\" rel=\"noopener noreferrer\">\n        <div class=\"wk-thumb\">\n          <div class=\"wk-mock\">\n            <div class=\"wk-bar\"><i></i><i></i><i></i></div>\n            <div class=\"wk-screen wk-screen-1\">\n              <div class=\"wks-nav\"><b>Matias Nature</b><span></span><span></span><span></span></div>\n              <div style=\"position:relative;flex:1;min-height:160px;border-radius:8px;overflow:hidden;border:1px solid var(--line)\"><img src=\"https://ctflpbjvsepkbfjpgkuh.supabase.co/storage/v1/object/public/project-images/matias-nature-projeto.webp\n\n\" alt=\"Matias Nature\" loading=\"lazy\" decoding=\"async\" style=\"position:absolute;inset:0;width:100%;height:100%;object-fit:cover\"/></div>\n            </div>\n          </div>\n        </div>\n        <div class=\"wk-meta\">\n          <div class=\"wk-titles\">\n            <h3>Matias Nature</h3>\n            <p>E-commerce + App PWA para marca de produtos naturais. Catálogo, checkout e área de cliente.</p>\n          </div>\n          <span class=\"wk-tag\">website</span>\n        </div>\n      </a><a class=\"wk-card reveal\" href=\"https://www.footballnationstore.pt/\" data-color=\"cyan\" target=\"_blank\" rel=\"noopener noreferrer\">\n        <div class=\"wk-thumb\">\n          <div class=\"wk-mock\">\n            <div class=\"wk-bar\"><i></i><i></i><i></i></div>\n            <div class=\"wk-screen wk-screen-1\">\n              <div class=\"wks-nav\"><b>FootballNationSore</b><span></span><span></span><span></span></div>\n              <div style=\"position:relative;flex:1;min-height:160px;border-radius:8px;overflow:hidden;border:1px solid var(--line)\"><img src=\"https://ctflpbjvsepkbfjpgkuh.supabase.co/storage/v1/object/public/project-images/football-projeto.webp\n\n\" alt=\"Website - Football Nation Store\" loading=\"lazy\" decoding=\"async\" style=\"position:absolute;inset:0;width:100%;height:100%;object-fit:cover\"/></div>\n            </div>\n          </div>\n        </div>\n        <div class=\"wk-meta\">\n          <div class=\"wk-titles\">\n            <h3>Website - Football Nation Store</h3>\n            <p>Loja online completa para venda de camisolas de futebol com catálogo, pagamentos e SEO.</p>\n          </div>\n          <span class=\"wk-tag\">website</span>\n        </div>\n      </a></div>\n  </div>\n</section>\n\n<!-- ========= COMPARAÇÃO ========= -->\n<section class=\"has-atmos\">\n  <div class=\"section-atmos\" aria-hidden=\"true\">\n    <div class=\"rings\"><span></span><span></span><span></span><span></span><span></span><span></span></div>\n    <div class=\"section-sparkles\">\n      <span style=\"left:14%;top:80px;animation-delay:.7s\"></span>\n      <span style=\"left:22%;top:180px;animation-delay:2.0s\"></span>\n      <span style=\"left:30%;top:60px;animation-delay:1.5s\"></span>\n      <span style=\"left:42%;top:130px;animation-delay:.3s\"></span>\n      <span style=\"left:50%;top:200px;animation-delay:2.6s\"></span>\n      <span style=\"left:58%;top:90px;animation-delay:1.0s\"></span>\n      <span style=\"left:66%;top:170px;animation-delay:3.2s\"></span>\n      <span style=\"left:74%;top:60px;animation-delay:1.9s\"></span>\n      <span style=\"left:82%;top:150px;animation-delay:.5s\"></span>\n      <span style=\"left:88%;top:220px;animation-delay:2.4s\"></span>\n    </div>\n  </div>\n  <div class=\"container\">\n    <div class=\"section-head reveal\">\n      <span class=\"eyebrow\">Comparação</span>\n      <h2 class=\"section-title\">Element Group vs <em>Outras Agências</em></h2>\n      <p class=\"section-sub\">Vê porque é que somos a escolha mais inteligente para o teu próximo projeto digital.</p>\n    </div>\n\n    <div class=\"vs-wrap reveal\">\n      <div class=\"vs-heads\">\n        <h3>Outras agências</h3>\n        <span class=\"brand\"><span class=\"e\">E</span> Element Group</span>\n        <div class=\"vs-badge\">V/S</div>\n      </div>\n      <div class=\"vs-rows\">\n        <div class=\"vs-cell lose\"><span class=\"vs-ic\">×</span>Templates pré-feitos, design igual a centenas de sites.</div>\n        <div class=\"vs-cell win\"><span class=\"vs-ic\">⚡</span>Design 100% à medida, único para o teu negócio.</div>\n\n        <div class=\"vs-cell lose\"><span class=\"vs-ic\">×</span>Apoio limitado pós-entrega — ficas por tua conta.</div>\n        <div class=\"vs-cell win\"><span class=\"vs-ic\">⚡</span>Apoio contínuo incluído, sempre que precisares.</div>\n\n        <div class=\"vs-cell lose\"><span class=\"vs-ic\">×</span>Performance média e tempos de carregamento lentos.</div>\n        <div class=\"vs-cell win\"><span class=\"vs-ic\">⚡</span>PageSpeed 95+ e velocidade de topo por defeito.</div>\n\n        <div class=\"vs-cell lose\"><span class=\"vs-ic\">×</span>Preços inflacionados: €2.000 – €5.000 por trabalhos básicos.</div>\n        <div class=\"vs-cell win\"><span class=\"vs-ic\">⚡</span>Preços justos desde 197€ — tecnologia moderna, custo reduzido.</div>\n\n        <div class=\"vs-cell lose\"><span class=\"vs-ic\">×</span>SEO básico, com pouca presença local.</div>\n        <div class=\"vs-cell win\"><span class=\"vs-ic\">⚡</span>SEO técnico avançado e Google Maps Top 3.</div>\n      </div>\n    </div>\n  </div>\n</section>\n\n<!-- ========= INSIGHTS — Stats com fontes citadas ========= -->\n<section id=\"insights\" class=\"insights-band\">\n  <div class=\"ib-beams\" aria-hidden=\"true\">\n    <span class=\"ib-beam ib-beam-l\"></span>\n    <span class=\"ib-beam ib-beam-l ib-beam-l2\"></span>\n    <span class=\"ib-beam ib-beam-r\"></span>\n    <span class=\"ib-beam ib-beam-r ib-beam-r2\"></span>\n    <div class=\"ib-grain\"></div>\n  </div>\n  <div class=\"container\">\n    <div class=\"insights-inner reveal\">\n      <span class=\"ib-eyebrow\">Insights da Indústria</span>\n      <h2 class=\"ib-title\">Cada segundo extra <em>custa-te</em> clientes</h2>\n      <p class=\"ib-sub\">Dados independentes mostram que performance e design impactam diretamente a conversão e retenção. É por isso que entregamos PageSpeed 95+ por defeito.</p>\n\n      <ul style=\"list-style:none;padding:0;margin:28px auto 32px;max-width:820px;display:grid;grid-template-columns:repeat(auto-fit,minmax(220px,1fr));gap:18px;text-align:left\">\n        <li style=\"padding:18px 20px;border-radius:14px;border:1px solid var(--line-2);background:rgba(255,255,255,.03)\">\n          <strong style=\"display:block;font-size:28px;font-weight:800;color:#fff;letter-spacing:-.02em\">88%</strong>\n          <span style=\"display:block;font-size:13.5px;color:var(--muted);line-height:1.55;margin-top:6px\">dos consumidores não voltam a um site após uma má experiência (<a href=\"https://www.amazonaws.cn/en/forrester-uxd-tech/\" rel=\"nofollow noopener\" target=\"_blank\" style=\"color:#a78bfa;text-decoration:underline\">Forrester via AWS</a>)</span>\n        </li>\n        <li style=\"padding:18px 20px;border-radius:14px;border:1px solid var(--line-2);background:rgba(255,255,255,.03)\">\n          <strong style=\"display:block;font-size:28px;font-weight:800;color:#fff;letter-spacing:-.02em\">+32%</strong>\n          <span style=\"display:block;font-size:13.5px;color:var(--muted);line-height:1.55;margin-top:6px\">probabilidade de bounce quando uma página demora 3s em vez de 1s a carregar (<a href=\"https://www.thinkwithgoogle.com/marketing-strategies/app-and-mobile/page-load-time-statistics/\" rel=\"nofollow noopener\" target=\"_blank\" style=\"color:#a78bfa;text-decoration:underline\">Google / Think with Google</a>)</span>\n        </li>\n        <li style=\"padding:18px 20px;border-radius:14px;border:1px solid var(--line-2);background:rgba(255,255,255,.03)\">\n          <strong style=\"display:block;font-size:28px;font-weight:800;color:#fff;letter-spacing:-.02em\">75%</strong>\n          <span style=\"display:block;font-size:13.5px;color:var(--muted);line-height:1.55;margin-top:6px\">dos utilizadores avaliam a credibilidade de um negócio com base no design do website (<a href=\"https://www.researchgate.net/publication/220371405_The_role_of_design_in_the_credibility_of_e-commerce_websites\" rel=\"nofollow noopener\" target=\"_blank\" style=\"color:#a78bfa;text-decoration:underline\">Stanford Web Credibility Research</a>)</span>\n        </li>\n      </ul>\n\n      <a class=\"btn-primary ib-btn\" href=\"/contacto\">Iniciar Projeto <svg width=\"14\" height=\"14\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2.4\"><path d=\"M7 17L17 7M9 7h8v8\"/></svg></a>\n    </div>\n  </div>\n</section>\n\n<!-- ========= TESTEMUNHOS ========= -->\n<section id=\"testemunhos\" class=\"has-atmos atmos-pro\">\n  <div class=\"atmos-rays\" aria-hidden=\"true\"></div>\n  <div class=\"section-atmos\" aria-hidden=\"true\">\n    <div class=\"rings\"><span></span><span></span><span></span><span></span><span></span><span></span></div>\n    <div class=\"section-sparkles\">\n      <span style=\"left:18%;top:80px;animation-delay:1.0s\"></span>\n      <span style=\"left:32%;top:200px;animation-delay:.5s\"></span>\n      <span style=\"left:48%;top:60px;animation-delay:2.2s\"></span>\n      <span style=\"left:62%;top:170px;animation-delay:1.4s\"></span>\n      <span style=\"left:78%;top:90px;animation-delay:.8s\"></span>\n    </div>\n  </div>\n  <div class=\"container\">\n    <div class=\"section-head reveal\">\n      <span class=\"eyebrow\">Testemunhos</span>\n      <h2 class=\"section-title\">Histórias de <em>sucesso</em> dos clientes</h2>\n      <p class=\"section-sub\">Descobre o que os nossos clientes dizem sobre as suas experiências e sucesso a trabalhar connosco.</p>\n    </div>\n    <div class=\"tx-wrap reveal\">\n      <button class=\"tx-arc tx-arc-l\" aria-hidden=\"true\"></button>\n      <button class=\"tx-arc tx-arc-r\" aria-hidden=\"true\"></button>\n      <div class=\"tx-stage\">\n        <article class=\"tx-card\" data-i=\"0\">\n        <div class=\"tx-bar\"></div>\n        <svg class=\"tx-quote\" width=\"42\" height=\"34\" viewBox=\"0 0 38 32\" fill=\"currentColor\"><path d=\"M0 18C0 8 6 2 16 0v6c-5 1-8 5-8 10h8v16H0V18zm22 0c0-10 6-16 16-18v6c-5 1-8 5-8 10h8v16H22V18z\"/></svg>\n        <p class=\"tx-text\">Recomendo totalmente o trabalho realizado na criação do meu site. Destaco o profissionalismo, a rapidez na execução e a excelente capacidade de transformar ideias em processos claros, simples e eficazes. Todo o desenvolvimento foi conduzido com grande organização, comunicação eficiente e foco na solução. O tratamento do projeto foi exemplar, com elevada qualidade técnica e prazos cumpridos de forma impressionante. Uma escolha segura para quem procura eficiência, rigor e resultados.</p>\n        <div class=\"tx-stars\"><span></span><span></span><span></span><span></span><span></span></div>\n        <div class=\"tx-author\">\n          <div class=\"tx-av has-photo\" data-i=\"RJ\"><img src=\"https://ctflpbjvsepkbfjpgkuh.supabase.co/storage/v1/object/public/review-avatars/ricardo-jesus.png\" alt=\"Ricardo Jesus\" loading=\"lazy\" decoding=\"async\"/></div>\n          <div><b>Ricardo Jesus</b><small>CEO · Apiários Terras da Pulga</small></div>\n        </div>\n      </article>\n<article class=\"tx-card\" data-i=\"1\">\n        <div class=\"tx-bar\"></div>\n        <svg class=\"tx-quote\" width=\"42\" height=\"34\" viewBox=\"0 0 38 32\" fill=\"currentColor\"><path d=\"M0 18C0 8 6 2 16 0v6c-5 1-8 5-8 10h8v16H0V18zm22 0c0-10 6-16 16-18v6c-5 1-8 5-8 10h8v16H22V18z\"/></svg>\n        <p class=\"tx-text\">Excelente profissional, bastante atencioso, simpático e empenhado no trabalho, com grandes capacidades de oferecer o melhor aos clientes, muito paciente e sempre atento para atender ao nosso gosto. Foi uma grande ajuda para o nosso negócio sem dúvida, muito obrigado #footballnationstore 😊</p>\n        <div class=\"tx-stars\"><span></span><span></span><span></span><span></span><span></span></div>\n        <div class=\"tx-author\">\n          <div class=\"tx-av has-photo\" data-i=\"MM\"><img src=\"https://ctflpbjvsepkbfjpgkuh.supabase.co/storage/v1/object/public/review-avatars/mariana-mendes.png\" alt=\"Mariana Mendes\" loading=\"lazy\" decoding=\"async\"/></div>\n          <div><b>Mariana Mendes</b><small>CEO · FootballNationStore</small></div>\n        </div>\n      </article>\n<article class=\"tx-card\" data-i=\"2\">\n        <div class=\"tx-bar\"></div>\n        <svg class=\"tx-quote\" width=\"42\" height=\"34\" viewBox=\"0 0 38 32\" fill=\"currentColor\"><path d=\"M0 18C0 8 6 2 16 0v6c-5 1-8 5-8 10h8v16H0V18zm22 0c0-10 6-16 16-18v6c-5 1-8 5-8 10h8v16H22V18z\"/></svg>\n        <p class=\"tx-text\">Desde o primeiro contacto até à entrega foi excecional! Criou o que eu pretendia há imenso tempo! Ficou um site extremamente incrível! Obrigada pela tua ajuda e pelo teu profissionalismo 🙏🏼</p>\n        <div class=\"tx-stars\"><span></span><span></span><span></span><span></span><span></span></div>\n        <div class=\"tx-author\">\n          <div class=\"tx-av has-photo\" data-i=\"MM\"><img src=\"https://ctflpbjvsepkbfjpgkuh.supabase.co/storage/v1/object/public/review-avatars/maria-mendes.png\" alt=\"Maria Mendes\" loading=\"lazy\" decoding=\"async\"/></div>\n          <div><b>Maria Mendes</b><small>CEO · Maria Mendes Massagens</small></div>\n        </div>\n      </article>\n<article class=\"tx-card\" data-i=\"3\">\n        <div class=\"tx-bar\"></div>\n        <svg class=\"tx-quote\" width=\"42\" height=\"34\" viewBox=\"0 0 38 32\" fill=\"currentColor\"><path d=\"M0 18C0 8 6 2 16 0v6c-5 1-8 5-8 10h8v16H0V18zm22 0c0-10 6-16 16-18v6c-5 1-8 5-8 10h8v16H22V18z\"/></svg>\n        <p class=\"tx-text\">Desde a primeira abordagem até ao conceito que pretendia foi super rápido e trabalho realizado com excelência e muito profissionalismo. Recomendo. Serviço premium. Obrigado.</p>\n        <div class=\"tx-stars\"><span></span><span></span><span></span><span></span><span></span></div>\n        <div class=\"tx-author\">\n          <div class=\"tx-av has-photo\" data-i=\"GN\"><img src=\"https://ctflpbjvsepkbfjpgkuh.supabase.co/storage/v1/object/public/review-avatars/goncalo-nascimento.png\" alt=\"Gonçalo Nascimento\" loading=\"lazy\" decoding=\"async\"/></div>\n          <div><b>Gonçalo Nascimento</b><small>CEO · Estrela Detail &amp; Wash</small></div>\n        </div>\n      </article>\n<article class=\"tx-card\" data-i=\"4\">\n        <div class=\"tx-bar\"></div>\n        <svg class=\"tx-quote\" width=\"42\" height=\"34\" viewBox=\"0 0 38 32\" fill=\"currentColor\"><path d=\"M0 18C0 8 6 2 16 0v6c-5 1-8 5-8 10h8v16H0V18zm22 0c0-10 6-16 16-18v6c-5 1-8 5-8 10h8v16H22V18z\"/></svg>\n        <p class=\"tx-text\">Excelente trabalho na elaboração e design com elevados padrões de qualidade e adequação às temáticas abordadas! Um exemplo de empenho e dedicação ao trabalho... Parabéns pelo excelente trabalho!</p>\n        <div class=\"tx-stars\"><span></span><span></span><span></span><span></span><span></span></div>\n        <div class=\"tx-author\">\n          <div class=\"tx-av has-photo\" data-i=\"DM\"><img src=\"https://ctflpbjvsepkbfjpgkuh.supabase.co/storage/v1/object/public/review-avatars/duarte-marvanejo.png\" alt=\"Duarte Marvanejo\" loading=\"lazy\" decoding=\"async\"/></div>\n          <div><b>Duarte Marvanejo</b><small>Presidente da Mesa da Assembleia Geral · ADSR</small></div>\n        </div>\n      </article>\n<article class=\"tx-card\" data-i=\"5\">\n        <div class=\"tx-bar\"></div>\n        <svg class=\"tx-quote\" width=\"42\" height=\"34\" viewBox=\"0 0 38 32\" fill=\"currentColor\"><path d=\"M0 18C0 8 6 2 16 0v6c-5 1-8 5-8 10h8v16H0V18zm22 0c0-10 6-16 16-18v6c-5 1-8 5-8 10h8v16H22V18z\"/></svg>\n        <p class=\"tx-text\">Trabalho TOP na criação do site da Associação Desportiva de São Romão.</p>\n        <div class=\"tx-stars\"><span></span><span></span><span></span><span></span><span></span></div>\n        <div class=\"tx-author\">\n          <div class=\"tx-av has-photo\" data-i=\"JS\"><img src=\"https://ctflpbjvsepkbfjpgkuh.supabase.co/storage/v1/object/public/review-avatars/jason-silva.png\" alt=\"Jason Silva\" loading=\"lazy\" decoding=\"async\"/></div>\n          <div><b>Jason Silva</b><small>Presidente do Conselho Fiscal · ADSR</small></div>\n        </div>\n      </article>\n<article class=\"tx-card\" data-i=\"6\">\n        <div class=\"tx-bar\"></div>\n        <svg class=\"tx-quote\" width=\"42\" height=\"34\" viewBox=\"0 0 38 32\" fill=\"currentColor\"><path d=\"M0 18C0 8 6 2 16 0v6c-5 1-8 5-8 10h8v16H0V18zm22 0c0-10 6-16 16-18v6c-5 1-8 5-8 10h8v16H22V18z\"/></svg>\n        <p class=\"tx-text\">Reitero em meu nome e em nome da\nADSR um enorme agradecimento, bem como, a recomendação da Element Group, na pessoa do Ricardo Costa pela competência e profissionalismo demonstrados na concepção deste projeto.</p>\n        <div class=\"tx-stars\"><span></span><span></span><span></span><span></span><span></span></div>\n        <div class=\"tx-author\">\n          <div class=\"tx-av has-photo\" data-i=\"RF\"><img src=\"https://ctflpbjvsepkbfjpgkuh.supabase.co/storage/v1/object/public/review-avatars/rafael-figueiredo.png\" alt=\"Rafael Figueiredo\" loading=\"lazy\" decoding=\"async\"/></div>\n          <div><b>Rafael Figueiredo</b><small>Presidente - ADSR</small></div>\n        </div>\n      </article>\n      </div>\n      <div class=\"tx-dots\" role=\"tablist\"></div>\n    </div>\n  </div>\n</section>\n\n<!-- ========= FAQ ========= -->\n<section id=\"faq\" class=\"atmos-pro\">\n  <div class=\"atmos-rays\" aria-hidden=\"true\"></div>\n  <div class=\"section-atmos\" aria-hidden=\"true\">\n    <div class=\"rings\"><span></span><span></span><span></span><span></span><span></span><span></span></div>\n    <div class=\"section-sparkles\">\n      <span style=\"left:16%;top:90px;animation-delay:1.4s\"></span>\n      <span style=\"left:24%;top:170px;animation-delay:.6s\"></span>\n      <span style=\"left:34%;top:60px;animation-delay:2.3s\"></span>\n      <span style=\"left:42%;top:140px;animation-delay:.2s\"></span>\n      <span style=\"left:50%;top:210px;animation-delay:3.0s\"></span>\n      <span style=\"left:58%;top:70px;animation-delay:1.7s\"></span>\n      <span style=\"left:66%;top:160px;animation-delay:2.5s\"></span>\n      <span style=\"left:74%;top:100px;animation-delay:.9s\"></span>\n      <span style=\"left:82%;top:200px;animation-delay:1.2s\"></span>\n      <span style=\"left:88%;top:230px;animation-delay:3.4s\"></span>\n    </div>\n  </div>\n  <div class=\"container\">\n    <div class=\"section-head reveal\">\n      <span class=\"eyebrow\">FAQ</span>\n      <h2 class=\"section-title\">Perguntas <em>frequentes</em></h2>\n      <p class=\"section-sub\">Respostas claras às dúvidas mais comuns sobre os nossos serviços.</p>\n    </div>\n\n    <div class=\"faq\">\n      <details><summary>Que serviços oferece a Element Group?<span class=\"plus\">+</span></summary><div class=\"ans\">Criação de websites, lojas online, apps mobile, design gráfico, branding, SEO e marketing digital — soluções completas para PMEs em Portugal.</div></details>\n      <details><summary>Quanto tempo demora um projeto?<span class=\"plus\">+</span></summary><div class=\"ans\">Sites institucionais entre 2 a 3 semanas. Lojas online e apps entre 4 a 8 semanas, dependendo da complexidade.</div></details>\n      <details><summary>Oferecem apoio após o lançamento?<span class=\"plus\">+</span></summary><div class=\"ans\">Sim. Todos os projetos incluem apoio pós-entrega, monitorização de performance e pequenas alterações sem custo adicional.</div></details>\n      <details><summary>Posso ver exemplos de trabalhos?<span class=\"plus\">+</span></summary><div class=\"ans\">Claro. Tens exemplos no portfólio em cima e podemos enviar-te casos de estudo detalhados por email.</div></details>\n      <details><summary>Como funcionam os pagamentos?<span class=\"plus\">+</span></summary><div class=\"ans\">Aceitamos pagamento único com 5% de desconto, ou 2× prestações sem juros. MBWay, Multibanco e transferência bancária.</div></details>\n      <details><summary>Oferecem alojamento e domínio?<span class=\"plus\">+</span></summary><div class=\"ans\">Sim. Tratamos do registo de domínio e alojamento performante com SSL incluído. Disponível como add-on mensal.</div></details>\n      <details><summary>Quantas alterações posso pedir?<span class=\"plus\">+</span></summary><div class=\"ans\">Dentro do âmbito acordado, alterações são ilimitadas. Trabalhamos por aprovações em cada fase para evitar surpresas.</div></details>\n      <details><summary>O SEO está incluído nos pacotes?<span class=\"plus\">+</span></summary><div class=\"ans\">SEO técnico, schema markup e otimização on-page estão sempre incluídos. SEO mensal é opcional no pacote de Marketing Digital.</div></details>\n    </div>\n  </div>\n</section>\n\n<!-- ========= CTA / CONTACTO ========= -->\n<section id=\"contacto\" style=\"padding:40px 0\">\n  <div class=\"cta-section reveal\">\n    <span class=\"eyebrow\" style=\"margin-bottom:14px\">Vamos falar</span>\n    <h2>Pronto para o próximo passo?</h2>\n    <p>Conta-nos sobre o teu projeto e recebe uma proposta personalizada em 24 horas.</p>\n    <div class=\"cta-checks\">\n      <span><svg width=\"16\" height=\"16\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"#c0a8ff\" stroke-width=\"2.2\"><path d=\"M5 12l4 4L19 6\"/></svg> Design à medida</span>\n      <span><svg width=\"16\" height=\"16\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"#c0a8ff\" stroke-width=\"2.2\"><path d=\"M5 12l4 4L19 6\"/></svg> Apoio contínuo</span>\n      <span><svg width=\"16\" height=\"16\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"#c0a8ff\" stroke-width=\"2.2\"><path d=\"M5 12l4 4L19 6\"/></svg> Entrega rápida</span>\n    </div>\n    <a class=\"btn-primary\" href=\"/contacto\" style=\"padding:16px 30px;font-size:15.5px\">Pedir Orçamento Grátis\n      <svg width=\"14\" height=\"14\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"#fff\" stroke-width=\"2.4\"><path d=\"M5 12h14M13 5l7 7-7 7\"/></svg>\n    </a>\n  </div>\n</section>\n\n<!-- ========= FOOTER ========= -->\n<footer class=\"site-footer\">\n  <div class=\"container\">\n    <div class=\"site-footer-grid\">\n\n      <!-- Marca -->\n      <div class=\"site-footer-brand\">\n        <a class=\"site-footer-logo\" href=\"/\">\n          <span class=\"site-footer-logo-mark\">E</span>\n          <span>Element Group</span>\n        </a>\n        <p>Soluções digitais à medida para PMEs em Portugal: websites, e-commerce, apps e marketing.</p>\n        <div class=\"site-footer-social\">\n          <a href=\"https://www.instagram.com/elementgroup.pt\" target=\"_blank\" rel=\"noopener noreferrer\" aria-label=\"Instagram\">\n            <svg width=\"15\" height=\"15\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"1.8\">\n              <path d=\"M7.8 2h8.4A5.8 5.8 0 0 1 22 7.8v8.4A5.8 5.8 0 0 1 16.2 22H7.8A5.8 5.8 0 0 1 2 16.2V7.8A5.8 5.8 0 0 1 7.8 2zM12 7a5 5 0 1 0 0 10A5 5 0 0 0 12 7zm6.5-.25a1.25 1.25 0 1 0-2.5 0 1.25 1.25 0 0 0 2.5 0zM12 9a3 3 0 1 1 0 6 3 3 0 0 1 0-6z\"/>\n            </svg>\n          </a>\n          <a href=\"https://www.facebook.com/elementgroupdigitalsolutions\" target=\"_blank\" rel=\"noopener noreferrer\" aria-label=\"Facebook\">\n            <svg width=\"15\" height=\"15\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"1.8\">\n              <path d=\"M18 2h-3a5 5 0 0 0-5 5v3H7v4h3v8h4v-8h3l1-4h-4V7a1 1 0 0 1 1-1h3z\"/>\n            </svg>\n          </a>\n          <a href=\"https://www.tiktok.com/@ricardo.elementgroup.pt\" target=\"_blank\" rel=\"noopener noreferrer\" aria-label=\"TikTok\">\n            <svg width=\"15\" height=\"15\" viewBox=\"0 0 24 24\" fill=\"currentColor\">\n              <path d=\"M19.59 6.69a4.83 4.83 0 0 1-3.77-4.25V2h-3.45v13.67a2.89 2.89 0 0 1-2.88 2.5 2.89 2.89 0 0 1-2.89-2.89 2.89 2.89 0 0 1 2.89-2.89c.28 0 .54.04.79.1V9.01a6.33 6.33 0 0 0-.79-.05 6.34 6.34 0 0 0-6.34 6.34 6.34 6.34 0 0 0 6.34 6.34 6.34 6.34 0 0 0 6.33-6.34V8.69a8.18 8.18 0 0 0 4.78 1.52V6.74a4.85 4.85 0 0 1-1.01-.05z\"/>\n            </svg>\n          </a>\n        </div>\n      </div>\n\n      <!-- Navegação -->\n      <div>\n        <h3>Navegação</h3>\n        <div class=\"site-footer-links\">\n          <a href=\"/\">Início</a>\n          <a href=\"/servicos\">Serviços</a>\n          <a href=\"/portfolio\">Portfolio</a>\n          <a href=\"/sobre\">Sobre</a>\n        </div>\n      </div>\n\n      <!-- Contacto -->\n      <div>\n        <h3>Contacto</h3>\n        <div class=\"site-footer-links\">\n          <a href=\"mailto:info@elementgroup.pt\">info@elementgroup.pt</a>\n          <a href=\"tel:+351930477894\">+351 930 477 894</a>\n          <a href=\"https://wa.me/351930477894\" target=\"_blank\" rel=\"noopener noreferrer\">WhatsApp</a>\n        </div>\n      </div>\n\n      <!-- Legal -->\n      <div>\n        <h3>Informação Legal</h3>\n        <div class=\"site-footer-links\">\n          <a href=\"/politica-de-privacidade\">Política de Privacidade</a>\n          <a href=\"/politica-de-cookies\">Política de Cookies</a>\n          <a href=\"/termos-e-condicoes\">Termos e Condições</a>\n          <a href=\"/resolucao-de-litigios\">Resolução de Litígios</a>\n          <a href=\"https://www.livroreclamacoes.pt/Inicio/\" target=\"_blank\" rel=\"noopener noreferrer\">Livro de Reclamações</a>\n        </div>\n      </div>\n\n    </div>\n\n    <div class=\"site-footer-bottom\">\n      <span>© 2026 Element Group. Todos os direitos reservados.</span>\n      <span>Agência digital em Portugal 🇵🇹</span>\n    </div>\n  </div>\n</footer>\nd:[[\"$\",\"div\",null,{\"dangerouslySetInnerHTML\":{\"__html\":\"$18\"}}],\"$L19\"]\n1a:I[6801,[\"974\",\"static/chunks/app/page-edb5d1bda91328a9.js\"],\"default\"]\n1b:T1768,// Duplica os cards do portfólio para loop infinito sem corte\nconst hpTrack = document.querySelector('.hp-track');\nif (hpTrack) {\n    hpTrack.insertAdjacentHTML('beforeend', hpTrack.innerHTML);\n}\n// Menu mobile da homepage\n(function() {\n    const menuBtn = document.getElementById('home-menu-btn');\n    const menu = document.getElementById('home-mobile-menu');\n    if (!menuBtn || !menu) return;\n    const setOpen = (open)=>{\n        menu.hidden = !open;\n        menuBtn.setAttribute('aria-expanded', String(open));\n        menuBtn.setAttribute('aria-label', open ? 'Fechar menu' : 'Abrir menu');\n        document.body.style.overflow = open ? 'hidden' : '';\n    };\n    menuBtn.addEventListener('click', ()=>{\n        const isOpen = menuBtn.getAttribute('aria-expanded') === 'true';\n        setOpen(!isOpen);\n    });\n    menu.querySelectorAll('a').forEach((link)=>{\n        link.addEventListener('click', ()=>setOpen(false));\n    });\n    window.addEventListener('keydown', (event)=>{\n        if (event.key === 'Escape') setOpen(false);\n    });\n    window.addEventListener('resize', ()=>{\n        if (window.innerWidth > 980) setOpen(false);\n    });\n})();\n// Carrossel 3D dos serviços\n(function() {\n    const stage = document.querySelector('.svc3d-stage');\n    if (!stage) return;\n    const cards = Array.from(stage.querySelectorAll('.card3d'));\n    const dotsWrap = document.querySelector('.svc3d-dots');\n    const prev = document.querySelector('.svc3d-nav.prev');\n    const next = document.querySelector('.svc3d-nav.next');\n    let idx = 0, timer = null;\n    const N = cards.length;\n    // dots\n    cards.forEach((_, i)=>{\n        const b = document.createElement('button');\n        b.type = 'button';\n        b.setAttribute('aria-label', 'Ir para serviço ' + (i + 1));\n        b.addEventListener('click', ()=>go(i, true));\n        dotsWrap.appendChild(b);\n    });\n    const dots = Array.from(dotsWrap.querySelectorAll('button'));\n    function place() {\n        cards.forEach((c, i)=>{\n            c.classList.remove('is-active', 'is-prev', 'is-next', 'is-prev2', 'is-next2');\n            const d = ((i - idx) % N + N) % N;\n            if (d === 0) c.classList.add('is-active');\n            else if (d === 1) c.classList.add('is-next');\n            else if (d === 2) c.classList.add('is-next2');\n            else if (d === N - 1) c.classList.add('is-prev');\n            else if (d === N - 2) c.classList.add('is-prev2');\n        });\n        dots.forEach((d, i)=>d.classList.toggle('is-on', i === idx));\n    }\n    function go(i, manual) {\n        idx = (i % N + N) % N;\n        place();\n        if (manual) {\n            restart();\n        }\n    }\n    function restart() {\n        if (timer) clearInterval(timer);\n        timer = setInterval(()=>go(idx + 1), 5000);\n    }\n    prev.addEventListener('click', ()=>go(idx - 1, true));\n    next.addEventListener('click', ()=>go(idx + 1, true));\n    cards.forEach((c, i)=>c.addEventListener('click', ()=>{\n            if (!c.classList.contains('is-active')) go(i, true);\n        }));\n    // pausa em hover\n    stage.parentElement.addEventListener('mouseenter', ()=>timer && clearInterval(timer));\n    stage.parentElement.addEventListener('mouseleave', restart);\n    place();\n    restart();\n})();\nconst io = new IntersectionObserver((entries)=>{\n    entries.forEach((e)=>{\n        if (e.isIntersecting) {\n            e.target.classList.add('in');\n            io.unobserve(e.target);\n        }\n    });\n}, {\n    threshold: .12\n});\ndocument.querySelectorAll('.reveal').forEach((el)=>io.observe(el));\n// Counter animado para .ct (estatísticas)\nconst counterIO = new IntersectionObserver((entries)=>{\n    entries.forEach((e)=>{\n        if (!e.isIntersecting) return;\n        const el = e.target;\n        const to = parseFloat(el.dataset.to);\n        const dec = parseInt(el.dataset.dec || '0', 10);\n        const dur = 1600;\n        const t0 = performance.now();\n        function step(t) {\n            const p = Math.min(1, (t - t0) / dur);\n            const eased = 1 - Math.pow(1 - p, 3);\n            el.textContent = (to * eased).toFixed(dec);\n            if (p < 1) requestAnimationFrame(step);\n            else el.textContent = to.toFixed(dec);\n        }\n        requestAnimationFrame(step);\n        counterIO.unobserve(el);\n    });\n}, {\n    threshold: .4\n});\ndocument.querySelectorAll('.ct').forEach((el)=>counterIO.observe(el));\ndocument.querySelectorAll('.feature').forEach((card)=>{\n    card.addEventListener('pointermove', (e)=>{\n        const r = card.getBoundingClientRect();\n        card.style.setProperty('--mx', (e.clientX - r.left) / r.width * 100 + '%');\n        card.style.setProperty('--my', (e.clientY - r.top) / r.height * 100 + '%');\n    });\n});\n// Carrossel de testemunhos (single-card)\n(function() {\n    const stage = document.querySelector('.tx-stage');\n    if (!stage) return;\n    const cards = Array.from(stage.querySelectorAll('.tx-card'));\n    const dotsWrap = document.querySelector('.tx-dots');\n    let i = 0, timer = null;\n    cards.forEach((_, k)=>{\n        const b = document.createElement('button');\n        b.type = 'button';\n        b.setAttribute('role', 'tab');\n        b.setAttribute('aria-label', 'Testemunho ' + (k + 1));\n        b.addEventListener('click', ()=>go(k, true));\n        dotsWrap.appendChild(b);\n    });\n    const dots = Array.from(dotsWrap.querySelectorAll('button'));\n    function paint() {\n        cards.forEach((c, k)=>c.classList.toggle('is-on', k === i));\n        dots.forEach((d, k)=>d.classList.toggle('is-on', k === i));\n    }\n    function go(k, manual) {\n        i = (k % cards.length + cards.length) % cards.length;\n        paint();\n        if (manual) restart();\n    }\n    function restart() {\n        clearInterval(timer);\n        timer = setInterval(()=>go(i + 1), 6000);\n    }\n    const wrap = document.querySelector('.tx-wrap');\n    wrap.addEventListener('mouseenter', ()=>clearInterval(timer));\n    wrap.addEventListener('mouseleave', restart);\n    paint();\n    restart();\n})();\n19:[\"$\",\"$L1a\",null,{\"code\":\"$1b\"}]\n"}