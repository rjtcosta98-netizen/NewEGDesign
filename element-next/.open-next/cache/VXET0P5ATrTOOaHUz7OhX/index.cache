HTML\":{\"__html\":\"{\\\"@context\\\":\\\"https://schema.org\\\",\\\"@type\\\":\\\"BreadcrumbList\\\",\\\"itemListElement\\\":[{\\\"@type\\\":\\\"ListItem\\\",\\\"position\\\":1,\\\"name\\\":\\\"Início\\\",\\\"item\\\":\\\"https://elementgroup.pt/\\\"},{\\\"@type\\\":\\\"ListItem\\\",\\\"position\\\":2,\\\"name\\\":\\\"Serviços\\\",\\\"item\\\":\\\"https://elementgroup.pt/servicos\\\"},{\\\"@type\\\":\\\"ListItem\\\",\\\"position\\\":3,\\\"name\\\":\\\"Portfólio\\\",\\\"item\\\":\\\"https://elementgroup.pt/portfolio\\\"},{\\\"@type\\\":\\\"ListItem\\\",\\\"position\\\":4,\\\"name\\\":\\\"Blog\\\",\\\"item\\\":\\\"https://elementgroup.pt/blog\\\"},{\\\"@type\\\":\\\"ListItem\\\",\\\"position\\\":5,\\\"name\\\":\\\"Contacto\\\",\\\"item\\\":\\\"https://elementgroup.pt/#contacto\\\"}]}\"}}]\nc:Tf61,{\"@context\":\"https://schema.org\",\"@type\":\"FAQPage\",\"mainEntity\":[{\"@type\":\"Question\",\"name\":\"Quanto custa fazer um website em Portugal?\",\"acceptedAnswer\":{\"@type\":\"Answer\",\"text\":\"Na Element Group, um website profissional começa em 197€ (pagamento único). Lojas online a partir de 997€ e apps mobile a partir de 1.497€. Onde agências tradicionais em Portugal facturam tipicamente entre €2.000 e €5.000 por sites comparáveis, conseguimos ser mais acessíveis porque usamos tecnologia moderna que reduz o tempo de produção sem comprometer qualidade.\"}},{\"@type\":\"Question\",\"name\":\"Qual a melhor agência digital para PMEs em Portugal?\",\"acceptedAnswer\":{\"@type\":\"Answer\",\"text\":\"A Element Group é uma agência digital portuguesa especializada em PMEs, com PageSpeed 95+ por defeito, preços a partir de 197€, propostas em 24 horas e apoio pós-lançamento incluído. Serve clientes em todo o território nacional remotamente.\"}},{\"@type\":\"Question\",\"name\":\"Quanto custa criar uma loja online em Portugal?\",\"acceptedAnswer\":{\"@type\":\"Answer\",\"text\":\"Uma loja online completa na Element Group começa em 997€ (pagamento único). Inclui checkout MBWay, Multibanco e cartão, gestão de produtos e stock, faturação automática portuguesa e SEO. Prazo de entrega: 4 a 6 semanas.\"}},{\"@type\":\"Question\",\"name\":\"Quanto tempo demora a fazer um site profissional?\",\"acceptedAnswer\":{\"@type\":\"Answer\",\"text\":\"Sites institucionais: 2 a 3 semanas. Lojas online: 4 a 6 semanas. Apps mobile: 6 a 8 semanas. Branding e logótipo: 1 a 2 semanas.\"}},{\"@type\":\"Question\",\"name\":\"Que serviços oferece a Element Group?\",\"acceptedAnswer\":{\"@type\":\"Answer\",\"text\":\"Criação de websites, lojas online (e-commerce), apps mobile (iOS, Android, PWA), design gráfico, branding, SEO técnico, SEO local e marketing digital — soluções completas para PMEs em Portugal.\"}},{\"@type\":\"Question\",\"name\":\"Oferecem apoio após o lançamento?\",\"acceptedAnswer\":{\"@type\":\"Answer\",\"text\":\"Sim. Todos os projetos incluem apoio pós-entrega, monitorização de performance e pequenas alterações sem custo adicional, dentro do âmbito acordado.\"}},{\"@type\":\"Question\",\"name\":\"Posso ver exemplos de trabalhos?\",\"acceptedAnswer\":{\"@type\":\"Answer\",\"text\":\"Sim. Casos: Apiários Terras da Pulga (loja online), Maria Mendes Massagens (Top 3 Google Local), AD São Romão (portal), Estrela Detail & Wash (branding) e Football Nation Store (e-commerce + branding). Casos de estudo detalhados disponíveis por email.\"}},{\"@type\":\"Question\",\"name\":\"Como funcionam os pagamentos?\",\"acceptedAnswer\":{\"@type\":\"Answer\",\"text\":\"Aceitamos pagamento único com 5% de desconto, ou 2× prestações sem juros. Métodos: MBWay, Multibanco e transferência bancária.\"}},{\"@type\":\"Question\",\"name\":\"Oferecem alojamento e domínio?\",\"acceptedAnswer\":{\"@type\":\"Answer\",\"text\":\"Sim. Tratamos do registo de domínio e alojamento performante com SSL incluído. Disponível como add-on mensal.\"}},{\"@type\":\"Question\",\"name\":\"Quantas alterações posso pedir?\",\"acceptedAnswer\":{\"@type\":\"Answer\",\"text\":\"Dentro do âmbito acordado, alterações são ilimitadas. Trabalhamos por aprovações em cada fase para evitar surpresas.\"}},{\"@type\":\"Question\",\"name\":\"O SEO está incluído nos pacotes?\",\"acceptedAnswer\":{\"@type\":\"Answer\",\"text\":\"SEO técnico, schema markup e otimização on-page estão sempre incluídos em todos os projetos. SEO mensal contínuo é opcional no pacote de Marketing Digital (desde 350€/mês).\"}},{\"@type\":\"Question\",\"name\":\"Element Group vs WordPress: qual escolher?\",\"acceptedAnswer\":{\"@type\":\"Answer\",\"text\":\"Sites WordPress com templates pré-feitos têm tipicamente performance média (PageSpeed 50-70) e dependem de plugins que aumentam a superfície de ataque e abrandam o site. A Element Group entrega sites à medida com PageSpeed 95+, sem plugins desnecessários e com SEO técnico avançado, a preços competitivos a partir de 197€.\"}}]}8:[\"$\",\"$L4\",null,{\"id\":\"ld-faq\",\"type\":\"application/ld+json\",\"strategy\":\"afterInteractive\",\"dangerouslySetInnerHTML\":{\"__html\":\"$c\"}}]\n9:[\"$\",\"$1\",\"c\",{\"children\":[\"$Ld\",null,[\"$\",\"$Le\",null,{\"children\":[\"$Lf\",[\"$\",\"$L10\",null,{\"promise\":\"$@11\"}]]}]]}]\na:[\"$\",\"$1\",\"h\",{\"children\":[null,[[\"$\",\"$L12\",null,{\"children\":\"$L13\"}],[\"$\",\"meta\",null,{\"name\":\"next-size-adjust\",\"content\":\"\"}]],[\"$\",\"$L14\",null,{\"children\":[\"$\",\"div\",null,{\"hidden\":true,\"children\":[\"$\",\"$15\",null,{\"fallback\":null,\"children\":\"$L16\"}]}]}]]}]\n13:[[\"$\",\"meta\",\"0\",{\"charSet\":\"utf-8\"}],[\"$\",\"meta\",\"1\",{\"name\":\"viewport\",\"content\":\"width=device-width, initial-scale=1\"}],[\"$\",\"meta\",\"2\",{\"name\":\"theme-color\",\"content\":\"#05070d\"}]]\nf:null\n17:I[5700,[],\"IconMark\"]\n11:{\"metadata\":[[\"$\",\"title\",\"0\",{\"children\":\"Element Group — Sites, Apps & Marketing Digital para PMEs\"}],[\"$\",\"meta\",\"1\",{\"name\":\"description\",\"content\":\"Soluções digitais à medida para PMEs em Portugal: websites, lojas online, apps mobile, branding e marketing digital. Propostas em 24h.\"}],[\"$\",\"meta\",\"2\",{\"name\":\"application-name\",\"content\":\"Element Group\"}],[\"$\",\"link\",\"3\",{\"rel\":\"manifest\",\"href\":\"/manifest.json\",\"crossOrigin\":\"$undefined\"}],[\"$\",\"meta\",\"4\",{\"name\":\"robots\",\"content\":\"index, follow, max-image-preview:large\"}],[\"$\",\"link\",\"5\",{\"rel\":\"canonical\",\"href\":\"https://elementgroup.pt\"}],[\"$\",\"meta\",\"6\",{\"name\":\"mobile-web-app-capable\",\"content\":\"yes\"}],[\"$\",\"meta\",\"7\",{\"name\":\"apple-mobile-web-app-title\",\"content\":\"Element Group\"}],[\"$\",\"meta\",\"8\",{\"name\":\"apple-mobile-web-app-status-bar-style\",\"content\":\"default\"}],[\"$\",\"meta\",\"9\",{\"property\":\"og:title\",\"content\":\"Element Group — Sites, Apps & Marketing Digital para PMEs\"}],[\"$\",\"meta\",\"10\",{\"property\":\"og:description\",\"content\":\"Soluções digitais à medida para PMEs em Portugal: websites, lojas online, apps mobile, branding e marketing digital. Propostas em 24h.\"}],[\"$\",\"meta\",\"11\",{\"property\":\"og:url\",\"content\":\"https://elementgroup.pt\"}],[\"$\",\"meta\",\"12\",{\"property\":\"og:site_name\",\"content\":\"Element Group\"}],[\"$\",\"meta\",\"13\",{\"property\":\"og:locale\",\"content\":\"pt_PT\"}],[\"$\",\"meta\",\"14\",{\"property\":\"og:image\",\"content\":\"https://elementgroup.pt/og-image.jpg\"}],[\"$\",\"meta\",\"15\",{\"property\":\"og:image:width\",\"content\":\"1200\"}],[\"$\",\"meta\",\"16\",{\"property\":\"og:image:height\",\"content\":\"630\"}],[\"$\",\"meta\",\"17\",{\"property\":\"og:type\",\"content\":\"website\"}],[\"$\",\"meta\",\"18\",{\"name\":\"twitter:card\",\"content\":\"summary_large_image\"}],[\"$\",\"meta\",\"19\",{\"name\":\"twitter:title\",\"content\":\"Element Group — Sites, Apps & Marketing Digital para PMEs\"}],[\"$\",\"meta\",\"20\",{\"name\":\"twitter:description\",\"content\":\"Soluções digitais à medida para PMEs em Portugal: websites, lojas online, apps mobile, branding e marketing digital. Propostas em 24h.\"}],[\"$\",\"meta\",\"21\",{\"name\":\"twitter:image\",\"content\":\"https://elementgroup.pt/og-image.jpg\"}],[\"$\",\"link\",\"22\",{\"rel\":\"icon\",\"href\":\"/favicon.ico\",\"type\":\"image/x-icon\",\"sizes\":\"48x48\"}],[\"$\",\"link\",\"23\",{\"rel\":\"icon\",\"href\":\"/icon0.svg?3b8331f96fba45c7\",\"type\":\"image/svg+xml\",\"sizes\":\"any\"}],[\"$\",\"link\",\"24\",{\"rel\":\"icon\",\"href\":\"/icon1.png?2dccf3bf3254d5b8\",\"type\":\"image/png\",\"sizes\":\"96x96\"}],[\"$\",\"link\",\"25\",{\"rel\":\"apple-touch-icon\",\"href\":\"/apple-icon.png?903b574816cb18b2\",\"type\":\"image/png\",\"sizes\":\"180x180\"}],[\"$\",\"$L17\",\"26\",{}]],\"error\":null,\"digest\":\"$undefined\"}\n16:\"$11:metadata\"\n18:T147ae,\n<div class=\"stars\"></div>\n\n<!-- ========= NAV ========= -->\n<div class=\"nav-wrap\">\n  <nav class=\"nav\">\n    <a class=\"brand\" href=\"#\">\n      <span class=\"mark\">E</span>\n      <span class=\"name\"><b>Element Group</b><small>Digital Solutions</small></span>\n    </a>\n    <div class=\"nav-links\">\n      <a href=\"/servicos\">Serviços</a>\n      <a href=\"/portfolio\">Portfolio</a>\n      <a href=\"/sobre\">Sobre</a>\n      <a href=\"#faq\">FAQ</a>\n    </div>\n    <div class=\"nav-cta\">\n      <a class=\"btn-ghost\" href=\"/contacto\">Contacto</a>\n      <a class=\"btn-primary\" href=\"/contacto\">Pedir Orçamento</a>\n      <button class=\"menu-btn\" id=\"home-menu-btn\" type=\"button\" aria-label=\"Abrir menu\" aria-controls=\"home-mobile-menu\" aria-expanded=\"false\">\n        <svg width=\"18\" height=\"18\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2\"><line x1=\"4\" y1=\"8\" x2=\"20\" y2=\"8\"/><line x1=\"4\" y1=\"16\" x2=\"20\" y2=\"16\"/></svg>\n      </button>\n    </div>\n  </nav>\n</div>\n\n<div class=\"home-mobile-menu\" id=\"home-mobile-menu\" hidden>\n  <a href=\"/servicos\">Serviços</a>\n  <a href=\"/portfolio\">Portfolio</a>\n  <a href=\"/sobre\">Sobre</a>\n  <a href=\"#faq\">FAQ</a>\n  <div class=\"home-mobile-menu-cta\">\n    <a class=\"btn-primary\" href=\"/contacto\">Pedir orçamento grátis</a>\n  </div>\n</div>\n\n<!-- ========= HERO ========= -->\n<header class=\"hero\">\n  <div class=\"planet\"></div>\n  <div class=\"glow-band\"></div>\n  <div class=\"grid-floor\"></div>\n\n  <div class=\"pill\">\n    <span class=\"pill-text\">Soluções digitais que <em style=\"font-style:italic;font-family:'Instrument Serif',serif;color:#c5b6ff\">transformam</em> negócios em Portugal</span>\n    <span class=\"arrow\"><svg width=\"14\" height=\"14\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"#fff\" stroke-width=\"2.4\"><path d=\"M5 12h14M13 5l7 7-7 7\"/></svg></span>\n  </div>\n\n  <h1 class=\"hero-title\">Websites &amp; <em>Marketing</em><br>que dão Resultados</h1>\n  <p class=\"hero-sub\">Criamos websites profissionais, lojas online e estratégias digitais para negócios portugueses. Tecnologia moderna, qualidade premium, preço justo.</p>\n\n  <div class=\"cta-row\">\n    <a class=\"btn-primary\" href=\"/contacto\">Começar Projeto\n      <svg width=\"14\" height=\"14\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"#fff\" stroke-width=\"2.4\"><path d=\"M5 12h14M13 5l7 7-7 7\"/></svg>\n    </a>\n    <span class=\"spots\"><span class=\"dot\"></span> Disponíveis para 3 novos projetos este mês</span>\n  </div>\n\n  <!-- Portfolio cards -->\n  <div class=\"hero-portfolio\">\n    <div class=\"hp-track\">\n\n    <div class=\"proj\" style=\"cursor:pointer\" onclick=\"window.open('https://apiariosterrasdapulga.pt','_blank','noopener,noreferrer')\">\n        <div class=\"preview\">\n          <span class=\"live\">Ver Live <svg width=\"11\" height=\"11\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2.5\"><path d=\"M7 17L17 7M9 7h8v8\"/></svg></span>\n          <img src=\"https://ctflpbjvsepkbfjpgkuh.supabase.co/storage/v1/object/public/hero-images/apiarios-terras-website.