isplay\":\"inline-block\"},\"children\":[\"$\",\"h2\",null,{\"style\":{\"fontSize\":14,\"fontWeight\":400,\"lineHeight\":\"49px\",\"margin\":0},\"children\":\"This page could not be found.\"}]}]]}]}]],[]],\"forbidden\":\"$undefined\",\"unauthorized\":\"$undefined\"}],[\"$\",\"script\",null,{\"type\":\"application/ld+json\",\"dangerouslySetInnerHTML\":{\"__html\":\"$4\"}}],\"$L5\",\"$L6\",\"$L7\"]}]]}]]}],{\"children\":[\"(pages)\",\"$L8\",{\"children\":[\"recursos\",\"$L9\",{\"children\":[[\"slug\",\"checklist-seo-pmes\",\"d\"],\"$La\",{\"children\":[\"__PAGE__\",\"$Lb\",{},null,false]},null,false]},null,false]},null,false]},null,false],\"$Lc\",false]],\"m\":\"$undefined\",\"G\":[\"$d\",[]],\"s\":false,\"S\":true}\nf:I[3728,[\"177\",\"static/chunks/app/layout-046c8189050ed762.js\"],\"\"]\n10:I[4466,[\"77\",\"static/chunks/77-2d69a11fd87f0c4e.js\",\"133\",\"static/chunks/app/(pages)/layout-d3c7b62d905185ae.js\"],\"default\"]\n11:I[3077,[\"77\",\"static/chunks/77-2d69a11fd87f0c4e.js\",\"265\",\"static/chunks/app/(pages)/recursos/%5Bslug%5D/page-d91c5c666973f072.js\"],\"\"]\n13:I[1777,[],\"OutletBoundary\"]\n15:I[8732,[],\"AsyncMetadataOutlet\"]\n17:I[1777,[],\"ViewportBoundary\"]\n19:I[1777,[],\"MetadataBoundary\"]\n1a:\"$Sreact.suspense\"\n5:[\"$\",\"script\",null,{\"type\":\"application/ld+json\",\"dangerouslySetInnerHTML\":{\"__html\":\"{\\\"@context\\\":\\\"https://schema.org\\\",\\\"@type\\\":\\\"WebSite\\\",\\\"@id\\\":\\\"https://elementgroup.pt/#website\\\",\\\"url\\\":\\\"https://elementgroup.pt/\\\",\\\"name\\\":\\\"Element Group\\\",\\\"inLanguage\\\":\\\"pt-PT\\\",\\\"publisher\\\":{\\\"@id\\\":\\\"https://elementgroup.pt/#organization\\\"}}\"}}]\ne:Tf61,{\"@context\":\"https://schema.org\",\"@type\":\"FAQPage\",\"mainEntity\":[{\"@type\":\"Question\",\"name\":\"Quanto custa fazer um website em Portugal?\",\"acceptedAnswer\":{\"@type\":\"Answer\",\"text\":\"Na Element Group, um website profissional começa em 197€ (pagamento único). Lojas online a partir de 997€ e apps mobile a partir de 1.497€. Onde agências tradicionais em Portugal facturam tipicamente entre €2.000 e €5.000 por sites comparáveis, conseguimos ser mais acessíveis porque usamos tecnologia moderna que reduz o tempo de produção sem comprometer qualidade.\"}},{\"@type\":\"Question\",\"name\":\"Qual a melhor agência digital para PMEs em Portugal?\",\"acceptedAnswer\":{\"@type\":\"Answer\",\"text\":\"A Element Group é uma agência digital portuguesa especializada em PMEs, com PageSpeed 95+ por defeito, preços a partir de 197€, propostas em 24 horas e apoio pós-lançamento incluído. Serve clientes em todo o território nacional remotamente.\"}},{\"@type\":\"Question\",\"name\":\"Quanto custa criar uma loja online em Portugal?\",\"acceptedAnswer\":{\"@type\":\"Answer\",\"text\":\"Uma loja online completa na Element Group começa em 997€ (pagamento único). Inclui checkout MBWay, Multibanco e cartão, gestão de produtos e stock, faturação automática portuguesa e SEO. Prazo de entrega: 4 a 6 semanas.\"}},{\"@type\":\"Question\",\"name\":\"Quanto tempo demora a fazer um site profissional?\",\"acceptedAnswer\":{\"@type\":\"Answer\",\"text\":\"Sites institucionais: 2 a 3 semanas. Lojas online: 4 a 6 semanas. Apps mobile: 6 a 8 semanas. Branding e logótipo: 1 a 2 semanas.\"}},{\"@type\":\"Question\",\"name\":\"Que serviços oferece a Element Group?\",\"acceptedAnswer\":{\"@type\":\"Answer\",\"text\":\"Criação de websites, lojas online (e-commerce), apps mobile (iOS, Android, PWA), design gráfico, branding, SEO técnico, SEO local e marketing digital — soluções completas para PMEs em Portugal.\"}},{\"@type\":\"Question\",\"name\":\"Oferecem apoio após o lançamento?\",\"acceptedAnswer\":{\"@type\":\"Answer\",\"text\":\"Sim. Todos os projetos incluem apoio pós-entrega, monitorização de performance e pequenas alterações sem custo adicional, dentro do âmbito acordado.\"}},{\"@type\":\"Question\",\"name\":\"Posso ver exemplos de trabalhos?\",\"acceptedAnswer\":{\"@type\":\"Answer\",\"text\":\"Sim. Casos: Apiários Terras da Pulga (loja online), Maria Mendes Massagens (Top 3 Google Local), AD São Romão (portal), Estrela Detail & Wash (branding) e Football Nation Store (e-commerce + branding). Casos de estudo detalhados disponíveis por email.\"}},{\"@type\":\"Question\",\"name\":\"Como funcionam os pagamentos?\",\"acceptedAnswer\":{\"@type\":\"Answer\",\"text\":\"Aceitamos pagamento único com 5% de desconto, ou 2× prestações sem juros. Métodos: MBWay, Multibanco e transferência bancária.\"}},{\"@type\":\"Question\",\"name\":\"Oferecem alojamento e domínio?\",\"acceptedAnswer\":{\"@type\":\"Answer\",\"text\":\"Sim. Tratamos do registo de domínio e alojamento performante com SSL incluído. Disponível como add-on mensal.\"}},{\"@type\":\"Question\",\"name\":\"Quantas alterações posso pedir?\",\"acceptedAnswer\":{\"@type\":\"Answer\",\"text\":\"Dentro do âmbito acordado, alterações são ilimitadas. Trabalhamos por aprovações em cada fase para evitar surpresas.\"}},{\"@type\":\"Question\",\"name\":\"O SEO está incluído nos pacotes?\",\"acceptedAnswer\":{\"@type\":\"Answer\",\"text\":\"SEO técnico, schema markup e otimização on-page estão sempre incluídos em todos os projetos. SEO mensal contínuo é opcional no pacote de Marketing Digital (desde 350€/mês).\"}},{\"@type\":\"Question\",\"name\":\"Element Group vs WordPress: qual escolher?\",\"acceptedAnswer\":{\"@type\":\"Answer\",\"text\":\"Sites WordPress com templates pré-feitos têm tipicamente performance média (PageSpeed 50-70) e dependem de plugins que aumentam a superfície de ataque e abrandam o site. A Element Group entrega sites à medida com PageSpeed 95+, sem plugins desnecessários e com SEO técnico avançado, a preços competitivos a partir de 197€.\"}}]}6:[\"$\",\"script\",null,{\"type\":\"application/ld+json\",\"dangerouslySetInnerHTML\":{\"__html\":\"$e\"}}]\n7:[[\"$\",\"$Lf\",null,{\"src\":\"https://www.googletagmanager.com/gtag/js?id=G-RNWM2MQTRT\",\"strategy\":\"afterInteractive\"}],[\"$\