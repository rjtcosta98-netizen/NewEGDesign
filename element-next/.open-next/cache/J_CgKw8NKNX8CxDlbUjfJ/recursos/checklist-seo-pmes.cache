st\",\"itemListElement\":[{\"@type\":\"ListItem\",\"position\":1,\"name\":\"Início\",\"item\":\"https://elementgroup.pt\"},{\"@type\":\"ListItem\",\"position\":2,\"name\":\"Recursos\",\"item\":\"https://elementgroup.pt/recursos\"},{\"@type\":\"ListItem\",\"position\":3,\"name\":\"Checklist SEO para PMEs\",\"item\":\"https://elementgroup.pt/recursos/checklist-seo-pmes\"}]},{\"@type\":\"Article\",\"headline\":\"Checklist SEO para PMEs\",\"description\":\"Checklist SEO gratuito para PMEs portuguesas: 20 pontos verificáveis para subir no Google. Sem jargão, 100% prático. Da Element Group.\",\"url\":\"https://elementgroup.pt/recursos/checklist-seo-pmes\",\"author\":{\"@type\":\"Organization\",\"name\":\"Element Group\",\"url\":\"https://elementgroup.pt\"},\"publisher\":{\"@type\":\"Organization\",\"name\":\"Element Group\",\"url\":\"https://elementgroup.pt\",\"logo\":{\"@type\":\"ImageObject\",\"url\":\"https://elementgroup.pt/og-image.jpg\"}},\"image\":\"https://elementgroup.pt/og-image.jpg\",\"datePublished\":\"2025-06-01\",\"dateModified\":\"2026-04-29\",\"inLanguage\":\"pt-PT\",\"isAccessibleForFree\":true,\"genre\":\"SEO\",\"keywords\":\"SEO, PME, Portugal, Checklist SEO para PMEs\"}]}</script><div class=\"lm-resource-page\"><nav class=\"lm-breadcrumb\" aria-label=\"Navegação\"><a class=\"lm-breadcrumb-link\" href=\"/\">Início</a><span class=\"lm-breadcrumb-sep\" aria-hidden=\"true\">/</span><a class=\"lm-breadcrumb-link\" href=\"/recursos\">Recursos</a><span class=\"lm-breadcrumb-sep\" aria-hidden=\"true\">/</span><span class=\"lm-breadcrumb-current\" aria-current=\"page\">Checklist SEO para PMEs</span></nav><div class=\"lm-resource-layout\"><div class=\"lm-resource-main\"><div class=\"lm-resource-meta-row\"><span class=\"lm-resource-category\">SEO</span><span class=\"lm-resource-meta-item\"><svg width=\"14\" height=\"14\" viewBox=\"0 0 24 24\" fill=\"none\" aria-hidden=\"true\"><circle cx=\"12\" cy=\"12\" r=\"10\" stroke=\"currentColor\" stroke-width=\"2\"></circl