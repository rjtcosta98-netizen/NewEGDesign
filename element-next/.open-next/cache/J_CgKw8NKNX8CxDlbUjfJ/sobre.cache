n\":[null,[\"$\",\"$L2\",null,{\"parallelRouterKey\":\"children\",\"error\":\"$undefined\",\"errorStyles\":\"$undefined\",\"errorScripts\":\"$undefined\",\"template\":[\"$\",\"$L3\",null,{}],\"templateStyles\":\"$undefined\",\"templateScripts\":\"$undefined\",\"notFound\":\"$undefined\",\"forbidden\":\"$undefined\",\"unauthorized\":\"$undefined\"}]]}]\na:[\"$\",\"$1\",\"c\",{\"children\":[[\"$\",\"div\",null,{\"className\":\"sv-page\",\"children\":[[\"$\",\"section\",null,{\"className\":\"sv-hero has-atmos\",\"children\":[[\"$\",\"div\",null,{\"className\":\"sv-hero-label\",\"children\":\"Sobre\"}],[\"$\",\"h1\",null,{\"children\":[\"Uma agência digital\",[\"$\",\"br\",null,{}],\"feita para \",[\"$\",\"em\",null,{\"children\":\"PMEs portuguesas.\"}]]}],[\"$\",\"p\",null,{\"className\":\"sv-hero-sub\",\"children\":\"A maioria das PMEs portuguesas paga milhares de euros por sites lentos, com templates reciclados que ninguém encontra no Google. A Element Group existe para mudar isto: sites à medida com PageSpeed 95+, a partir de 197€, entregues em 2 a 3 semanas. Fundada e liderada por Ricardo Jorge, sem intermediários.\"}]]}],[\"$\",\"section\",null,{\"style\":{\"maxWidth\":820,\"margin\":\"0 auto\",\"padding\":\"0 20px 60px\",\"color\":\"var(--text)\",\"lineHeight\":1.75,\"fontSize\":16},\"children\":[[\"$\",\"h2\",null,{\"style\":{\"fontSize\":26,\"fontWeight\":800,\"color\":\"#fff\",\"letterSpacing\":\"-.02em\",\"marginTop\":32},\"children\":\"A nossa missão\"}],[\"$\",\"p\",null,{\"children\":[\"Em Portugal, a maioria das PMEs paga entre \",[\"$\",\"b\",null,{\"children\":\"€2.000 e €5.000\"}],\" \",\"por websites com performance medíocre, templates reciclados e plugins inseguros. A Element Group existe para mudar isto:\",\" \",[\"$\",\"b\",null,{\"children\":\"entregamos sites com PageSpeed 95+ a partir de 197€\"}],\", construídos sobre a mesma stack moderna que potencia produtos como Netflix, TikTok e GitHub (Next.js, React, Vercel) — o que nos permite reduzir drasticamente o tempo de produção sem sacrificar qualidade.\"]}],[\"$\",\"h2\",null,{\"style\":{\"fontSize\":26,\"fontWeight\":800,\"color\":\"#fff\",\"letterSpacing\":\"-.02em\",\"marginTop\":40},\"children\":\"Quem está por trás\"}],[\"$\",\"p\",null,{\"children\":[[\"$\",\"b\",null,{\"children\":\"Ricardo Jorge\"}],\" é o fundador e developer principal da Element Group. Com formação e experiência prática em desenvolvimento web moderno (React, Next.js, TypeScript), SEO técnico avançado, schema markup e otimização de Core Web Vitals, lidera todos os projetos de início ao fim — não há intermediários, account managers ou departamentos a passar o teu projeto entre mãos.\"]}],[\"$\",\"p\",null,{\"children\":[\"Esta abordagem direta significa que o que pedes é o que entregamos: \",[\"$\",\"b\",null,{\"children\":\"resposta em horas, não dias\"}],\"; decisões técnicas explicadas em português claro, não em jargão; e total transparência em prazos e preços.\"]}],[\"$\",\"h2\",null,{\"style\":{\"fontSize\":26,\"fontWeight\":800,\"color\":\"#fff\",\"letterSpacing\":\"-.02em\",\"marginTop\":40},\"children\":\"O que nos diferencia\"}],[\"$\",\"ul\",null,{\"style\":{\"paddingLeft\":22},\"children\":[[\"$\",\"li\",null,{\"children\":[[\"$\",\"b\",null,{\"children\":\"PageSpeed 95+\"}],\" em todos os projetos, por defeito (não como upsell).\"]}],[\"$\",\"li\",null,{\"children\":[[\"$\",\"b\",null,{\"children\":\"Código 100% à medida\"}],\", sem templates WordPress nem page builders.\"]}],[\"$\",\"li\",null,{\"children\":[[\"$\",\"b\",null,{\"children\":\"SEO técnico + schema markup\"}],\" incluídos, não cobrados à parte.\"]}],[\"$\",\"li\",null,{\"children\":[[\"$\",\"b\",null,{\"children\":\"Apoio pós-lançamento\"}],\" contínuo dentro do âmbito acordado, sem mensalidade obrigatória.\"]}],[\"$\",\"li\",null,{\"children\":[[\"$\",\"b\",null,{\"children\":\"Preços transparentes\"}],\" — publicados em\",\" \",[\"$\",\"a\",null,{\"href\":\"/servicos\",\"style\":{\"color\":\"#a78bfa\"},\