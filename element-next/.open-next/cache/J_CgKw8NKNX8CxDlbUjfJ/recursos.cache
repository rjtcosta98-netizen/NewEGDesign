stion\\\",\\\"name\\\":\\\"Quanto custa criar uma loja online em Portugal?\\\",\\\"acceptedAnswer\\\":{\\\"@type\\\":\\\"Answer\\\",\\\"text\\\":\\\"Uma loja online completa na Element Group começa em 997€ (pagamento único). Inclui checkout MBWay, Multibanco e cartão, gestão de produtos e stock, faturação automática portuguesa e SEO. Prazo de entrega: 4 a 6 semanas.\\\"}},{\\\"@type\\\":\\\"Question\\\",\\\"name\\\":\\\"Quanto tempo demora a fazer um site profissional?\\\",\\\"acceptedAnswer\\\":{\\\"@type\\\":\\\"Answer\\\",\\\"text\\\":\\\"Sites institucionais: 2 a 3 semanas. Lojas online: 4 a 6 semanas. Apps mobile: 6 a 8 semanas. Branding e logótipo: 1 a 2 semanas.\\\"}},{\\\"@type\\\":\\\"Question\\\",\\\"name\\\":\\\"Que serviços oferece a Element Group?\\\",\\\"acceptedAnswer\\\":{\\\"@type\\\":\\\"Answer\\\",\\\"text\\\":\\\"Criação de websites, lojas online (e-commerce), apps mobile (iOS, Android, PWA), design gráfico, branding, SEO técnico, SEO local e marketing digital — soluções completas para PMEs em Portugal.\\\"}},{\\\"@type\\\":\\\"Question\\\",\\\"name\\\":\\\"Oferecem apoio após o lançamento?\\\",\\\"acceptedAnswer\\\":{\\\"@type\\\":\\\"Answer\\\",\\\"text\\\":\\\"Sim. Todos os projetos incluem apoio pós-entrega, monitorização de performance e pequenas alterações sem custo adicional, dentro do âmbito acordado.\\\"}},{\\\"@type\\\":\\\"Question\\\",\\\"name\\\":\\\"Posso ver exemplos de trabalhos?\\\",\\\"acceptedAnswer\\\":{\\\"@type\\\":\\\"Answer\\\",\\\"text\\\":\\\"Sim. Casos: Apiários Terras da Pulga (loja online), Maria Mendes Massagens (Top 3 Google Local), AD São Romão (portal), Estrela Detail \\u0026 Wash (branding) e Football Nation Store (e-commerce + branding). Casos de estudo detalhados disponíveis por email.\\\"}},{\\\"@type\\\":\\\"Question\\\",\\\"name\\\":\\\"Como funcionam os pagamentos?\\\",\\\"acceptedAnswer\\\":{\\\"@type\\\":\\\"Answer\\\",\\\"text\\\":\\\"Aceitamos pagamento único com 5% de desconto, ou 2× prestações sem juros. Métodos: MBWay, Multibanco e transferência bancária.\\\"}},{\\\"@type\\\":\\\"Question\\\",\\\"name\\\":\\\"Oferecem alojamento e domínio?\\\",\\\"acceptedAnswer\\\":{\\\"@type\\\":\\\"Answer\\\",\\\"text\\\":\\\"Sim. Tratamos do registo de domínio e alojamento performante com SSL incluído. Disponível como add-on mensal.\\\"}},{\\\"@type\\\":\\\"Question\\\",\\\"name\\\":\\\"Quantas alterações posso pedir?\\\",\\\"acceptedAnswer\\\":{\\\"@type\\\":\\\"Answer\\\",\\\"text\\\":\\\"Dentro do âmbito acordado, alterações são ilimitadas. Trabalhamos por aprovações em cada fase para evitar surpresas.\\\"}},{\\\"@type\\\":\\\"Question\\\",\\\"name\\\":\\\"O SEO está incluído nos pacotes?\\\",\\\"acceptedAnswer\\\":{\\\"@type\\\":\\\"Answer\\\",\\\"text\\\":\\\"SEO técnico, schema markup e otimização on-page estão sempre incluídos em todos os projetos. SEO mensal contínuo é opcional no pacote de Marketing Digital (desde 350€/mês).\\\"}},{\\\"@type\\\":\\\"Question\\\",\\\"name\\\":\\\"Element Group vs WordPress: qual escolher?\\\",\\\"acceptedAnswer\\\":{\\\"@type\\\":\\\"Answer\\\",\\\"text\\\":\\\"Sites WordPress com templates pré-feitos têm tipicamente performance média (PageSpeed 50-70) e dependem de plugins que aumentam a superfície de ataque e abrandam o site. A Element Group entrega sites à medida com PageSpeed 95+, sem plugins desnecessários e com SEO técnico avançado, a preços competitivos a partir de 197€.\\\"}}]}\"])</script><script>self.__next_f.push([1,\"6:[\\\"$\\\",\\\"script\\\",null,{\\\"type\\\":\\\"application/ld+json\\\",\\\"dangerouslySetInnerHTML\\\":{\\\"__html\\\":\\\"$d\\\"}}]\\n7:[[\\\"$\\\",\\\"$Le\\\",null,{\\\"src\\\":\\\"https://www.googletagmanager.com/gtag/js?id=G-RNWM2MQTRT\\\",\\\"strategy\\\":\\\"afterInteractive\\\"}],[\\\"$\\\",\\\"$Le\\\",null,{\\\"id\\\":\\\"ga4-init\\\",\\\"strategy\\\":\\\"afterInteractive\\\",\\\"children\\\":\\\"\\\\n                window.dataLayer = window.dataLayer || [];\\\\n                function gtag(){d